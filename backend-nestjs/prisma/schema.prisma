generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model GithubRepo {
  id             BigInt   @id @default(autoincrement())
  repoName       String?  @map("repo_name") @db.VarChar(255)
  fullName       String?  @map("full_name") @db.VarChar(500) @unique
  description    String?  @map("description") @db.Text
  descriptionCn  String?  @map("description_cn") @db.Text
  readmeCn       String?  @map("readme_cn") @db.LongText
  readmeOriginal String?  @map("readme_original") @db.LongText
  readmeFetched  Boolean  @default(false) @map("readme_fetched") @db.TinyInt
  language       String?  @map("language") @db.VarChar(100)
  ownerName      String?  @map("owner_name") @db.VarChar(255)
  ownerAvatarUrl String?  @map("owner_avatar_url") @db.VarChar(1000)
  htmlUrl        String?  @map("html_url") @db.VarChar(1000)
  homepage       String?  @map("homepage") @db.VarChar(1000)
  starsCount     Int      @default(0) @map("stars_count")
  forksCount     Int      @default(0) @map("forks_count")
  watchersCount  Int      @default(0) @map("watchers_count")
  openIssuesCount Int     @default(0) @map("open_issues_count")
  topics         String?  @map("topics") @db.Text
  licenseName    String?  @map("license_name") @db.VarChar(255)
  isFork         Boolean  @default(false) @map("is_fork") @db.TinyInt
  isArchived     Boolean  @default(false) @map("is_archived") @db.TinyInt
  repoCreatedAt  DateTime? @map("repo_created_at") @db.DateTime
  repoUpdatedAt  DateTime? @map("repo_updated_at") @db.DateTime
  repoPushedAt   DateTime? @map("repo_pushed_at") @db.DateTime
  starredAt      DateTime? @map("starred_at") @db.DateTime
  createdAt      DateTime? @map("created_at") @db.DateTime
  updatedAt      DateTime? @map("updated_at") @db.DateTime

  // 关联
  repoCategories  RepoCategory[]
  translationItems TranslationTaskItem[]

  @@index([language])
  @@index([ownerName])
  @@index([starredAt])
  @@index([starsCount])
  @@index([repoUpdatedAt])
  @@map("github_repo")
}

model Category {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(100) @unique
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  parentId    BigInt?  @map("parent_id")
  level       Int?     @default(1)
  createdAt   DateTime? @map("created_at") @db.DateTime
  updatedAt   DateTime? @map("updated_at") @db.DateTime

  // 自引用 (在 service 层处理)
  // 关联
  repoCategories RepoCategory[]

  @@map("category")
}

model RepoCategory {
  id         BigInt    @id @default(autoincrement())
  repoId     BigInt    @map("repo_id")
  categoryId BigInt    @map("category_id")
  createdAt  DateTime? @map("created_at") @db.DateTime

  repo     GithubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  category Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([repoId, categoryId])
  @@index([categoryId])
  @@index([repoId])
  @@map("repo_category")
}

model SyncLog {
  id           BigInt    @id @default(autoincrement())
  syncType     String?   @map("sync_type") @db.VarChar(50)
  status       String?   @map("status") @db.VarChar(50)
  totalCount   Int?      @map("total_count")
  syncedCount  Int?      @map("synced_count")
  startedAt    DateTime? @map("started_at") @db.DateTime
  finishedAt   DateTime? @map("finished_at") @db.DateTime
  errorMessage String?   @map("error_message") @db.Text
  createdAt    DateTime? @default(now()) @map("created_at") @db.DateTime

  @@index([status])
  @@index([createdAt])
  @@map("sync_log")
}

model SystemConfig {
  id          BigInt    @id @default(autoincrement())
  configKey   String    @map("config_key") @db.VarChar(255) @unique
  configValue String?   @map("config_value") @db.Text
  description String?   @map("description") @db.VarChar(500)
  createdAt   DateTime? @default(now()) @map("created_at") @db.DateTime
  updatedAt   DateTime? @map("updated_at") @db.DateTime

  @@map("system_config")
}

model CloneTask {
  id             BigInt    @id @default(autoincrement())
  taskId         String    @map("task_id") @db.VarChar(64) @unique
  status         String?   @default("PENDING") @map("status") @db.VarChar(32)
  totalRepos     Int       @default(0) @map("total_repos")
  completedRepos Int       @default(0) @map("completed_repos")
  failedRepos    Int       @default(0) @map("failed_repos")
  skippedRepos   Int       @default(0) @map("skipped_repos")
  errorMessage   String?   @map("error_message") @db.Text
  keyword        String?   @map("keyword") @db.VarChar(255)
  language       String?   @map("language") @db.VarChar(255)
  categoryIds    String?   @map("category_ids") @db.VarChar(255)
  dateField      String?   @map("date_field") @db.VarChar(64)
  startDate      String?   @map("start_date") @db.VarChar(16)
  endDate        String?   @map("end_date") @db.VarChar(16)
  sortBy         String?   @map("sort_by") @db.VarChar(64)
  sortOrder      String?   @map("sort_order") @db.VarChar(16)
  subDirectory   String?   @map("sub_directory") @db.VarChar(255)
  targetDir      String?   @map("target_dir") @db.VarChar(500)
  concurrency    Int       @default(5) @map("concurrency")
  cloneDepth     Int       @default(1) @map("clone_depth")
  maxRepoSizeMb  Int       @default(500) @map("max_repo_size_mb")
  startedAt      DateTime? @map("started_at") @db.DateTime
  finishedAt     DateTime? @map("finished_at") @db.DateTime
  createdAt      DateTime? @default(now()) @map("created_at") @db.DateTime
  pinned         Int       @default(0)
  cancelled      Int       @default(0)

  items CloneTaskItem[]

  @@index([status])
  @@index([createdAt])
  @@map("clone_task")
}

model CloneTaskItem {
  id        BigInt    @id @default(autoincrement())
  taskId    String    @map("task_id") @db.VarChar(64)
  fullName  String    @map("full_name") @db.VarChar(500)
  status    String    @map("status") @db.VarChar(32)
  message   String?   @map("message") @db.Text
  createdAt DateTime? @default(now()) @map("created_at") @db.DateTime

  cloneTask CloneTask @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@index([taskId])
  @@index([fullName])
  @@map("clone_task_item")
}

model AiAnalyzeTask {
  id         BigInt    @id @default(autoincrement())
  taskId     String    @map("task_id") @db.VarChar(64) @unique
  type       String    @db.VarChar(32)
  status     String    @default("PROCESSING") @db.VarChar(32)
  content    String?   @db.LongText
  params     String?   @db.Text
  createdAt  DateTime? @default(now()) @map("created_at") @db.DateTime
  finishedAt DateTime? @map("finished_at") @db.DateTime

  @@index([status])
  @@index([createdAt])
  @@map("ai_analyze_task")
}

model TranslationTask {
  id               BigInt    @id @default(autoincrement())
  status           String?   @default("PENDING") @map("status") @db.VarChar(50)
  totalItems       Int       @default(0) @map("total_items")
  completedItems   Int       @default(0) @map("completed_items")
  failedItems      Int       @default(0) @map("failed_items")
  descTotal        Int       @default(0) @map("desc_total")
  descCompleted    Int       @default(0) @map("desc_completed")
  descFailed       Int       @default(0) @map("desc_failed")
  readmeTotal      Int       @default(0) @map("readme_total")
  readmeCompleted  Int       @default(0) @map("readme_completed")
  readmeFailed     Int       @default(0) @map("readme_failed")
  createdAt        DateTime? @default(now()) @map("created_at") @db.DateTime
  finishedAt       DateTime? @map("finished_at") @db.DateTime

  items TranslationTaskItem[]

  @@map("translation_task")
}

model TranslationTaskItem {
  id            BigInt    @id @default(autoincrement())
  taskId        BigInt    @map("task_id")
  repoId        BigInt    @map("repo_id")
  fullName      String?   @map("full_name") @db.VarChar(500)
  translateType String    @map("translate_type") @db.VarChar(20)
  status        String?   @default("PENDING") @map("status") @db.VarChar(50)
  retryCount    Int       @default(0) @map("retry_count")
  errorMessage  String?   @map("error_message") @db.Text
  createdAt     DateTime? @default(now()) @map("created_at") @db.DateTime
  updatedAt     DateTime? @map("updated_at") @db.DateTime

  task TranslationTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  repo GithubRepo       @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([repoId])
  @@index([status])
  @@map("translation_task_item")
}
