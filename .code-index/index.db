 params.sortOrder)\n  if (params.dateField) searchParams.set('dateField', params.dateField)\n  if (params.startMonth) searchParams.set('startMonth', params.startMonth)\n  if (params.endMonth) searchParams.set('endMonth', params.endMonth)\n  const { data } = await api.get<PageResult<GithubRepo>>('/api/stars', { params: searchParams })\n  return data\n}"}},{"name":"fetchStarDetail","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stars.ts","lineNumber":19,"language":"typescript","dependencies":[],"purpose":"Function fetchStarDetail implementation","context":"Located in stars.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.get"],"usedImports":["api"],"body":"{\n  const params = backQuery ? { backQuery } : {}\n  const { data } = await api.get<string>(`/stars/${id}`, { params })\n  return data\n}"}},{"name":"exportStarsUrls","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stars.ts","lineNumber":25,"language":"typescript","dependencies":[],"purpose":"Function exportStarsUrls implementation","context":"Located in stars.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":1,"functionCalls":["searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","./request#api.get"],"usedImports":["StarListParams","api"],"body":"{\n  const searchParams = new URLSearchParams()\n  if (params.keyword) searchParams.set('keyword', params.keyword)\n  if (params.language) searchParams.set('language', params.language)\n  if (params.sortBy) searchParams.set('sortBy', params.sortBy)\n  if (params.sortOrder) searchParams.set('sortOrder', params.sortOrder)\n  if (params.dateField) searchParams.set('dateField', params.dateField)\n  if (params.startMonth) searchParams.set('startMonth', params.startMonth)\n  if (params.endMonth) searchParams.set('endMonth', params.endMonth)\n  const