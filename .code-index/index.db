     const res = await categoriesApi.deleteCategory(id)\n          if (res.success) {\n            message.success('删除成功')\n            setSelectedRowKeys((prev) => prev.filter((k) => k !== id))\n            fetchData()\n          } else {\n            message.error(res.message || '删除失败')\n          }\n        } catch {\n          message.error('删除失败，请稍后重试')\n        }\n      },\n    })\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320085,"version":0},"$loki":38},{"name":"handleBatchDelete","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":124,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleBatchDelete","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["message.warning","modal.confirm","../api/categories#categoriesApi.batchDeleteCategories","message.success","setSelectedRowKeys","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error"],"usedImports":["categoriesApi"],"body":"{\n    if (selectedRowKeys.length === 0) {\n      message.warning('请先选择要删除的分类')\n      return\n    }\n    modal.confirm({\n      title: '批量删除',\n      content: `确定要删除选中的 ${selectedRowKeys.length} 个分类吗？分类下的仓库将变为未分类状态。`,\n      okText: '确认删除',\n      okType: 'danger',\n      cancelText: '取消',\n      onOk: async () => {\n        try {\n          const res = await categoriesApi.batchDeleteCategories(selectedRowKeys as number[])\n          if (res.success) {\n            message.success('批量删除成功')\n            setSelectedRowKeys([])\n            fetchData()\n          } else {\n            message.error(res.message || '批量删除失败')\n          }\n        } catch {\n          message.error('批量删除失败，请稍后重试')\n        }\n      },\n    })\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320087,"version":0},"$loki":39},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":158,"startLine":158,"endLine":160,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["a"],"isExported":false,"complexity":1,"body":"(\n        <a onClick={() => navigate(`/categories/${record.id}`)}>{name}</a>\n      )","usedImports":["Category"],"calledBy":[]},"meta":{"revision":0,"created":1780675320088,"version":0},"$loki":40},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":187,"startLine":187,"endLine":207,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["div","Button","EditOutlined","DeleteOutlined"],"isExported":false,"complexity":1,"body":"(\n        <div style={{ display: 'flex', gap: 8 }}>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            icon={<EditOutlined />}\n            onClick={() => openEditModal(record)}\n          >\n            编辑\n          </Button>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            danger\n            icon={<DeleteOutlined />}\n            onClick={() => handleDelete(record.id, record.name)}\n          >\n            删除\n          </Button>\n        </div>\n      )","usedImports":["Category","Button","EditOutlined","DeleteOutlined"],"calledBy":[]},"meta":{"revision":0,"created":1780675320091,"version":0},"$loki":41},{"name":"Classify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":16,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["antd#App.useApp","useState","useState","useState","useState","useState","useState","useState","useState","useRef","setLoading","../api/classify#classifyApi.fetchClassifyRepos","Array.isArray","setRepos","Array.isArray","setRepos","setRepos","message.error","setRepos","setLoading","useEffect","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx#fetchRepos","useMemo","repos.forEach","set.add","sort","Array.from","useMemo","keyword.toLowerCase","list.filter","includes","r.fullName.toLowerCase","includes","r.description.toLowerCase","list.filter","setSelectedIds","filteredRepos.map","setSelectedIds","setClassifying","setResults","../api/classify#classifyApi.executeClassify","setResults","message.success","Object.keys","setTimeout","resultsRef.current.scrollIntoView","message.error","message.error","setClassifying","v.slice","toFixed","String","languages.map","setKeyword","setSelectedIds","Object.keys","map","Object.entries","repoList.map","r.description.slice"],"usedImports":["App","useState","GithubRepo","useRef","classifyApi","useEffect","useMemo","GithubOutlined","Tag","Card","Row","Col","Select","Input","Button","ClearOutlined","RobotOutlined","Table","Spin"],"body":"{\n  const { message } = App.useApp()\n\n  const [repos, setRepos] = useState<GithubRepo[]>([])\n  const [selectedIds, setSelectedIds] = useState<number[]>([])\n  const [keyword, setKeyword] = useState('')\n  const [language, setLanguage] = useState('')\n  const [topN, setTopN] = useState(8)\n  const [loading, setLoading] = useState(false)\n  const [classifying, setClassifying] = useState(false)\n  const [results, setResults] = useState<Record<string, GithubRepo[]>>({})\n\n  const resultsRef = useRef<HTMLDivElement>(null)\n\n  const fetchRepos = async () => {\n    setLoading(true)\n    try {\n      const res = await classifyApi.fetchClassifyRepos()\n      if (Array.isArray(res)) {\n        setRepos(res)\n      } else if (res && typeof res === 'object' && 'repos' in res && Array.isArray((res as Record<string, unknown>).repos)) {\n        setRepos((res as Record<string, GithubRepo[]>).repos)\n      } else {\n        setRepos([])\n      }\n    } catch {\n      message.error('获取仓库列表失败')\n      setRepos([])\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    fetchRepos()\n  }, [])\n\n  const languages = useMemo(() => {\n    const set = new Set<string>()\n    repos.forEach((r) => {\n      if (r.language) set.add(r.language)\n    })\n    return Array.from(set).sort()\n  }, [repos])\n\n  const filteredRepos = useMemo(() => {\n    let list = repos\n    if (keyword) {\n      const kw = keyword.toLowerCase()\n      list = list.filter(\n        (r) =>\n          r.fullName.toLowerCase().includes(kw) ||\n          (r.description !== null && r.description.toLowerCase().includes(kw))\n      )\n    }\n    if (language) {\n      list = list.filter((r) => r.language === language)\n    }\n    return list\n  }, [repos, keyword, language])\n\n  const handleSelectAll = () => {\n    setSelectedIds(filteredRepos.map((r) => r.id))\n  }\n\n  const handleClearSelection = () => {\n    setSelectedIds([])\n  }\n\n  const handleClassify = async () => {\n    if (selectedIds.length === 0) return\n    setClassifying(true)\n    setResults({})\n    try {\n      const res = await classifyApi.executeClassify(selectedIds, topN)\n      if (res.success && res.categories) {\n        setResults(res.categories)\n        message.success(`AI 分类完成，共 ${Object.keys(res.categories).length} 个分类`)\n        setTimeout(() => {\n          resultsRef.current?.scrollIntoView({ behavior: 'smooth', block: 'start' })\n        }, 150)\n      } else {\n        message.error('AI 分类失败，请稍后重试')\n      }\n    } catch {\n      message.error('AI 分类请求失败')\n    } finally {\n      setClassifying(false)\n    }\n  }\n\n  const columns = [\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      width: 240,\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 6 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '描述',\n      dataIndex: 'description',\n      key: 'description',\n      ellipsis: true,\n      render: (v: string | null) => {\n        if (!v) return '-'\n        return v.length > 80 ? v.slice(0, 80) + '...' : v\n      },\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 120,\n      render: (lang: string | null) =>\n        lang ? <Tag color=\"blue\">{lang}</Tag> : <Tag color=\"default\">-</Tag>,\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => {\n        if (v >= 1000) return (v / 1000).toFixed(1) + 'K'\n        return String(v)\n      },\n    },\n  ]\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        AI 智能分类\n      </Title>\n\n      <Card style={{ marginBottom: 16 }}>\n        <Row gutter={[12, 12]} align=\"middle\">\n          <Col>\n            <Select\n              placeholder=\"选择语言\"\n              allowClear\n              style={{ width: 150 }}\n              value={language || undefined}\n              onChange={setLanguage}\n              options={languages.map((l) => ({ label: l, value: l }))}\n            />\n          </Col>\n          <Col>\n            <Input.Search\n              placeholder=\"搜索仓库...\"\n              allowClear\n              style={{ width: 250 }}\n              value={keyword}\n              onChange={(e) => setKeyword(e.target.value)}\n              onSearch={setKeyword}\n            />\n          </Col>\n          <Col>\n            <Button onClick={handleSelectAll}>全选</Button>\n          </Col>\n          <Col>\n            <Button onClick={handleClearSelection} icon={<ClearOutlined />}>\n              清除选择\n            </Button>\n          </Col>\n          <Col>\n            <Text type=\"secondary\">\n              已选 <Text strong>{selectedIds.length}</Text> 项\n            </Text>\n          </Col>\n          <Col>\n            <Select\n              value={topN}\n              onChange={setTopN}\n              options={TOP_N_OPTIONS}\n              style={{ width: 100 }}\n            />\n          </Col>\n          <Col>\n            <Button\n              type=\"primary\"\n              icon={<RobotOutlined />}\n              disabled={selectedIds.length === 0}\n              onClick={handleClassify}\n            >\n              开始 AI 分类\n            </Button>\n          </Col>\n        </Row>\n      </Card>\n\n      <Card>\n        <Table\n          rowSelection={{\n            selectedRowKeys: selectedIds,\n            onChange: (keys) => setSelectedIds(keys as number[]),\n          }}\n          columns={columns}\n          dataSource={filteredRepos}\n          rowKey=\"id\"\n          loading={loading}\n          pagination={{\n            showSizeChanger: true,\n            showTotal: (total: number) => `共 ${total} 个仓库`,\n            pageSizeOptions: ['10', '20', '50', '100'],\n          }}\n          scroll={{ x: 700 }}\n          size=\"small\"\n        />\n      </Card>\n\n      {Object.keys(results).length > 0 && (\n        <div ref={resultsRef} style={{ marginTop: 24 }}>\n          <Title level={4} style={{ marginBottom: 16 }}>\n            分类结果\n          </Title>\n          <Row gutter={[16, 16]}>\n            {Object.entries(results).map(([category, repoList]) => (\n              <Col xs={24} md={12} lg={8} key={category}>\n                <Card\n                  title={\n                    <Text strong style={{ fontSize: 15 }}>\n                      {category}\n                    </Text>\n                  }\n                  extra={<Tag>{repoList.length} 个仓库</Tag>}\n                  style={{ height: '100%' }}\n                >\n                  {repoList.map((r) => (\n                    <div key={r.id} style={{ padding: '4px 0' }}>\n                      <a\n                        href={r.htmlUrl}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        style={{ fontSize: 13 }}\n                      >\n                        {r.fullName}\n                      </a>\n                      {r.description && (\n                        <div style={{ color: '#888', fontSize: 12, marginTop: 2 }}>\n                          {r.description.length > 60\n                            ? r.description.slice(0, 60) + '...'\n                            : r.description}\n                        </div>\n                      )}\n                    </div>\n                  ))}\n                </Card>\n              </Col>\n            ))}\n          </Row>\n        </div>\n      )}\n\n      {classifying && (\n        <div\n          style={{\n            position: 'fixed',\n            inset: 0,\n            background: 'rgba(0, 0, 0, 0.45)',\n            display: 'flex',\n            flexDirection: 'column',\n            alignItems: 'center',\n            justifyContent: 'center',\n            zIndex: 9999,\n          }}\n        >\n          <Spin size=\"large\" />\n          <div style={{ color: '#fff', fontSize: 16, marginTop: 16 }}>\n            AI 正在分析仓库...\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":19,"customHook":false},{"name":"useState","line":20,"customHook":false},{"nam