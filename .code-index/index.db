alledBy":[]},"meta":{"revision":0,"created":1780675320112,"version":0},"$loki":51},{"name":"parseTopics","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":40,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"Function parseTopics implementation","context":"Located in StarDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["JSON.parse"],"usedImports":[],"body":"{\n  if (!topics) return []\n  try {\n    return JSON.parse(topics)\n  } catch {\n    return []\n  }\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320113,"version":0},"$loki":52},{"name":"StarDetail","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":49,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in StarDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useParams","useLocation","useNavigate","useState","useState","useState","useEffect","setLoading","setNotFound","Number","Promise.allSettled","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","topRes.value.find","recentRes.value.find","setRepo","setNotFound","setNotFound","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#fetchRepo","navigate","navigate","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#parseTopics","window.open","window.open","topics.map","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate"],"usedImports":["useParams","useLocation","useNavigate","useState","GithubRepo","useEffect","statsApi","Spin","Button","ArrowLeftOutlined","Card","Empty","Avatar","Tag","Space","GithubOutlined","LinkOutlined","Row","Col","Statistic","StarFilled","ForkOutlined","EyeOutlined","BugOutlined","Descriptions"],"body":"{\n  const { id } = useParams<{ id: string }>()\n  const location = useLocation()\n  const navigate = useNavigate()\n\n  const [repo, setRepo] = useState<GithubRepo | null>(\n    (location.state as { repo?: GithubRepo })?.repo ?? null,\n  )\n  const [loading, setLoading] = useState(!repo)\n  const [notFound, setNotFound] = useState(false)\n\n  useEffect(() => {\n    if (repo) return\n\n    const fetchRepo = async () => {\n      setLoading(true)\n      setNotFound(false)\n      const numericId = Number(id)\n\n      try {\n        const [topRes, recentRes] = await Promise.allSettled([\n          statsApi.fetchTopStarredRepos(100),\n          statsApi.fetchRecentActiveRepos(100),\n        ])\n\n        let found: GithubRepo | undefined\n\n        if (topRes.status === 'fulfilled') {\n          found = topRes.value.find((r) => r.id === numericId)\n        }\n        if (!found && recentRes.status === 'fulfilled') {\n          found = recentRes.value.find((r) => r.id === numericId)\n        }\n\n        if (found) {\n          setRepo(found)\n        } else {\n          setNotFound(true)\n        }\n      } catch {\n        setNotFound(true)\n      } finally {\n        setLoading(false)\n      }\n    }\n\n    fetchRepo()\n  }, [id, repo])\n\n  const handleBack = () => {\n    if (window.history.length > 1) {\n      navigate(-1)\n    } else {\n      navigate('/')\n    }\n  }\n\n  if (loading) {\n    return (\n      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: 400 }}>\n        <Spin size=\"large\" tip=\"加载中...\" />\n      </div>\n    )\n  }\n\n  if (notFound || !repo) {\n    return (\n      <div>\n        <Button\n          icon={<ArrowLeftOutlined />}\n          onClick={handleBack}\n          style={{ marginBottom: 24 }}\n        >\n          返回\n        </Button>\n        <Card>\n          <Empty description=\"未找到该仓库数据\">\n            <Button type=\"primary\" onClick={() => navigate('/')}>\n              返回列表\n            </Button>\n          </Empty>\n        </Card>\n      </div>\n    )\n  }\n\n  const topics = parseTopics(repo.topics)\n\n  const statColStyle = { xs: 12 as const, sm: 12 as const, md: 6 as const }\n\n  return (\n    <div>\n      <Button\n        icon={<ArrowLeftOutlined />}\n        onClick={handleBack}\n        style={{ marginBottom: 20 }}\n      >\n        返回\n      </Button>\n\n      <Card style={{ marginBottom: 20 }}>\n        <div style={{ display: 'flex', alignItems: 'flex-start', gap: 16 }}>\n          <Avatar\n            src={repo.ownerAvatarUrl}\n            alt={repo.ownerName}\n            size={64}\n            style={{ flexShrink: 0 }}\n          />\n          <div style={{ flex: 1, minWidth: 0 }}>\n            <Title level={4} style={{ margin: 0, marginBottom: 4 }}>\n              {repo.fullName}\n            </Title>\n            <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n              <Text type=\"secondary\" style={{ fontSize: 14 }}>\n                {repo.ownerName}\n              </Text>\n              {repo.isFork && (\n                <Tag color=\"orange\" style={{ margin: 0 }}>\n                  已 Fork\n                </Tag>\n              )}\n              {repo.isArchived && (\n                <Tag color=\"default\" style={{ margin: 0 }}>\n                  已归档\n                </Tag>\n              )}\n            </div>\n            {repo.description && (\n              <Paragraph type=\"secondary\" style={{ marginBottom: 0 }}>\n                {repo.description}\n              </Paragraph>\n            )}\n          </div>\n          <Space>\n            <Button\n              type=\"primary\"\n              icon={<GithubOutlined />}\n              onClick={() => window.open(repo.htmlUrl, '_blank', 'noopener,noreferrer')}\n            >\n              在 GitHub 上查看\n            </Button>\n            {repo.homepage && (\n              <Button\n                icon={<LinkOutlined />}\n                onClick={() => window.open(repo.homepage!, '_blank', 'noopener,noreferrer')}\n              >\n                访问项目主页\n              </Button>\n            )}\n          </Space>\n        </div>\n      </Card>\n\n      <Card style={{ marginBottom: 20 }}>\n        <Row gutter={[16, 16]}>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Stars\"\n                value={repo.starsCount}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Forks\"\n                value={repo.forksCount}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Watchers\"\n                value={repo.watchersCount}\n                prefix={<EyeOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Open Issues\"\n                value={repo.openIssuesCount}\n                prefix={<BugOutlined style={{ color: '#ff4d4f' }} />}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Card>\n\n      <Card title=\"详细信息\">\n        <Descriptions column={{ xs: 1, sm: 1, md: 2 }} bordered size=\"small\">\n          <Descriptions.Item label=\"编程语言\">\n            {repo.language ? (\n              <Tag color=\"blue\">{repo.language}</Tag>\n            ) : (\n              <Text type=\"secondary\">-</Text>\n            )}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"许可证\">\n            {repo.licenseName ? (\n              <Text>{repo.licenseName}</Text>\n            ) : (\n              <Text type=\"secondary\">-</Text>\n            )}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"主题标签\" span={2}>\n            {topics.length > 0 ? (\n              <Space size={[4, 4]} wrap>\n                {topics.map((topic) => (\n                  <Tag key={topic}>{topic}</Tag>\n                ))}\n              </Space>\n            ) : (\n              <Text type=\"secondary\">-</Text>\n            )}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"Star 时间\">\n            {formatDate(repo.starredAt)}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"仓库创建时间\">\n            {formatDate(repo.repoCreatedAt)}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"最后更新时间\">\n            {formatDate(repo.repoUpdatedAt)}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"最后推送时间\">\n            {formatDate(repo.repoPushedAt)}\n          </Descriptions.Item>\n        </Descriptions>\n      </Card>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useParams","line":50,"customHook":true},{"name":"useLocation","line":51,"customHook":true},{"name":"useNavigate","line":52,"customHook":true},{"name":"useState","line":54,"customHook":false},{"name":"useState","line":57,"customHook":false},{"name":"useState","line":58,"customHook":false},{"name":"useEffect","line":60,"customHook":false}],"jsxElements":["div","Spin","Button","ArrowLeftOutlined","Card","Empty","Avatar","Title","Text","Tag","Paragraph","