ategory"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":187,"startLine":187,"endLine":207,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["div","Button","EditOutlined","DeleteOutlined"],"isExported":false,"complexity":1,"body":"(\n        <div style={{ display: 'flex', gap: 8 }}>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            icon={<EditOutlined />}\n            onClick={() => openEditModal(record)}\n          >\n            编辑\n          </Button>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            danger\n            icon={<DeleteOutlined />}\n            onClick={() => handleDelete(record.id, record.name)}\n          >\n            删除\n          </Button>\n        </div>\n      )","usedImports":["Category","Button","EditOutlined","DeleteOutlined"],"calledBy":[]}},{"name":"Classify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":16,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["antd#App.useApp","useState","useState","useState","useState","useState","useState","useState","useState","useRef","setLoading","../api/classify#classifyApi.fetchClassifyRepos","Array.isArray","setRepos","Array.isArray","setRepos","setRepos","message.error","setRepos","setLoading","useEffect","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx#fetchRepos","useMemo","repos.forEach","set.add","sort","Array.from","useMemo","keyword.toLowerCase","list.filter","includes","r.fullName.toLowerCase","includes","r.description.toLowerCase","list.filter","setSelectedIds","filteredRepos.map","setSelectedIds","setClassifying","setResults","../api/classify#classifyApi.executeClassify","setResults","message.success","Object.keys","setTimeout","resultsRef.current.scrollIntoView","message.error","message.error","setClassifying","v.slice","toFixed","String","languages.map","setKeyword","setSelectedIds","Object.keys","map","Object.entries","repoList.map","r.description.slice"],"usedImports":["App","useState","GithubRepo","useRef","classifyApi","useEffect","useMemo","GithubOutlined","Tag","Card","Row","Col","Select","Input","Button","ClearOutlined","RobotOutlined","Table","Spin"],"body":"{\n  const { message } = App.useApp()\n\n  const [repos, setRepos] = useState<GithubRepo[]>([])\n  const [selectedIds, setSelectedIds] = useState<number[]>([])\n  const [keyword, setKeyword] = useState('')\n  const [language, setLanguage] = useState('')\n  const [topN, setTopN] = useState(8)\n  const [loading, setLoading] = useState(false)\n  const [classifying, setClassifying] = useState(false)\n  const [results, setResults] = useState<Record<string, GithubRepo[]>>({})\n\n  const resultsRef = useRef<HTMLDivElement>(null)\n\n  const fetchRepos = async () => {\n    setLoading(true)\n    try {\n      const res = await classifyApi.fetchClassifyRepos()\n      if (Array.isArray(res)) {\n        setRepos(res)\n      } else if (res && typeof res === 'object' && 'repos' in res && Array.isArray((res as Record<string, unknown>).repos)) {\n        setRepos((res as Record<string, GithubRepo[]>).repos)\n      } else {\n        setRepos([])\n      }\n    } catch {\n      message.error('获取仓库列表失败')\n      setRepos([])\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    fetchRepos()\n  }, [])\n\n  const languages = useMemo(() => {\n    const set = new Set<string>()\n    repos.forEach((r) => {\n      if (r.language) set.add(r.language)\n    })\n    return Array.from(set).sort()\n  }, [repos])\n\n  const filteredRepos = useMemo(() => {\n    let list = repos\n    if (keyword) {\n      const kw = keyword.toLowerCase()\n      list = list.filter(\n        (r) =>\n          r.fullName.toLowerCase().includes(kw) ||\n          (r.description !== null && r.description.toLowerCase().includes(kw))\n      )\n    }\n    if (language) {\n      list = list.filter((r) => r.language === language)\n    }\n    return list\n  }, [repos, keyword, language])\n\n  const handleSelectAll = () => {\n    setSelectedIds(filteredRepos.map((r) => r.id))\n  }\n\n  const handleClearSelection = () => {\n    setSelectedIds([])\n  }\n\n  const handleClassify = async () => {\n    if (selectedIds.length === 0) return\n    setClassifying(true)\n    setResults({})\n    try {\n      const res = await classifyApi.executeClassify(selectedIds, topN)\n      if (res.success && res.categories) {\n        setResults(res.categories)\n        message.success(`AI 分类完成，共 ${Object.keys(res.categories).length} 个分类`)\n        setTimeout(() => {\n          resultsRef.current?.scrollIntoView({ behavior: 'smooth', block: 'start' })\n        }, 150)\n      } else {\n        message.error('AI 分类失败，请稍后重试')\n      }\n    } catch {\n      message.error('AI 分类请求失败')\n    } finally {\n      setClassifying(false)\n    }\n  }\n\n  const columns = [\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      width: 240,\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 6 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '描述',\n      dataIndex: 'description',\n      key: 'description',\n      ellipsis: true,\n      render: (v: string | null) => {\n        if (!v) return '-'\n        return v.length > 80 ? v.slice(0, 80) + '...' : v\n      },\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 120,\n      render: (lang: string | null) =>\n        lang ? <Tag color=\"blue\">{lang}</Tag> : <Tag color=\"default\">-</Tag>,\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => {\n        if (v >= 1000) return (v / 1000).toFixed(1) + 'K'\n        return String(v)\n      },\n    },\n  ]\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        AI 智能分类\n      </Title>\n\n      <Card style={{ marginBottom: 16 }}>\n        <Row gutter={[12, 12]} align=\"middle\">\n          <Col>\n            <Select\n              placeholder=\"选择语言\"\n              allowClear\n              style={{ width: 150 }}\n              value={language || undefined}\n              onChange={setLanguage}\n              options={languages.map((l) => ({ label: l, value: l }))}\n            />\n          </Col>\n          <Col>\n            <Input.Search\n              placeholder=\"搜索仓库...\"\n              allowClear\n              style={{ width: 250 }}\n              value={keyword}\n              onChange={(e) => setKeyword(e.target.value)}\n              onSearch={setKeyword}\n            />\n          </Col>\n          <Col>\n            <Button onClick={handleSelectAll}>全选</Button>\n          </Col>\n          <Col>\n            <Button onClick={handleClearSelection} icon={<ClearOutlined />}>\n              清除选择\n            </Button>\n          </Col>\n          <Col>\n            <Text type=\"secondary\">\n              已选 <Text strong>{selectedIds.length}</Text> 项\n            </Text>\n          </Col>\n          <Col>\n            <Select\n              value={topN}\n              onChange={setTopN}\n              options={TOP_N_OPTIONS}\n              style={{ width: 100 }}\n            />\n          </Col>\n          <Col>\n            <Button\n              type=\"primary\"\n              icon={<RobotOutlined />}\n              disabled={selectedIds.length === 0}\n              onClick={handleClassify}\n            >\n              开始 AI 分类\n            </Button>\n          </Col>\n        </Row>\n      </Card>\n\n      <Card>\n        <Table\n          rowSelection={{\n            selectedRowKeys: selectedIds,\n            onChange: (keys) => setSelectedIds(keys as number[]),\n          }}\n          columns={columns}\n          dataSource={filteredRepos}\n          rowKey=\"id\"\n          loading={loading}\n          pagination={{\n            showSizeChanger: true,\n            showTotal: (total: number) => `共 ${total} 个仓库`,\n            pageSizeOptions: ['10', '20', '50', '100'],\n          }}\n          scroll={{ x: 700 }}\n          size=\"small\"\n        />\n      </Card>\n\n      {Object.keys(results).length > 0 && (\n        <div ref={resultsRef} style={{ marginTop: 24 }}>\n          <Title level={4} style={{ marginBottom: 16 }}>\n            分类结果\n          </Title>\n          <Row gutter={[16, 16]}>\n            {Object.entries(results).map(([category, repoList]) => (\n              <Col xs={24} md={12} lg={8} key={category}>\n                <Card\n                  title={\n                    <Text strong style={{ fontSize: 15 }}>\n                      {category}\n                    </Text>\n                  }\n                  extra={<Tag>{repoList.length} 个仓库</Tag>}\n                  style={{ height: '100%' }}\n                >\n                  {repoList.map((r) => (\n                    <div key={r.id} style={{ padding: '4px 0' }}>\n                      <a\n                        href={r.htmlUrl}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        style={{ fontSize: 13 }}\n                      >\n                        {r.fullName}\n                      </a>\n                      {r.description && (\n                        <div style={{ color: '#888', fontSize: 12, marginTop: 2 }}>\n                          {r.description.length > 60\n                            ? r.description.slice(0, 60) + '...'\n                            : r.description}\n                        </div>\n                      )}\n                    </div>\n                  ))}\n                </Card>\n              </Col>\n            ))}\n          </Row>\n        </div>\n      )}\n\n      {classifying && (\n        <div\n          style={{\n            position: 'fixed',\n            inset: 0,\n            background: 'rgba(0, 0, 0, 0.45)',\n            display: 'flex',\n            flexDirection: 'column',\n            alignItems: 'center',\n            justifyContent: 'center',\n            zIndex: 9999,\n          }}\n        >\n          <Spin size=\"large\" />\n          <div style={{ color: '#fff', fontSize: 16, marginTop: 16 }}>\n            AI 正在分析仓库...\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":19,"customHook":false},{"name":"useState","line":20,"customHook":false},{"name":"useState","line":21,"customHook":false},{"name":"useState","line":22,"customHook":false},{"name":"useState","line":23,"customHook":false},{"name":"useState","line":24,"customHook":false},{"name":"useState","line":25,"customHook":false},{"name":"useState","line":26,"customHook":false},{"name":"useRef","line":28,"customHook":false},{"name":"useEffect","line":49,"customHook":false},{"name":"useMemo","line":53,"customHook":false},{"name":"useMemo","line":61,"customHook":false}],"jsxElements":["a","GithubOutlined","Tag","div","Title","Card","Row","Col","Select","Input.Search","Button","ClearOutlined","Text","RobotOutlined","Table","Spin"],"complexity":17}},{"name":"fetchRepos","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":30,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"Arrow function fetchRepos","context":"Defined in Classify.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","../api/classify#classifyApi.fetchClassifyRepos","Array.isArray","setRepos","Array.isArray","setRepos","setRepos","message.error","setRepos","setLoading"],"usedImports":["classifyApi","GithubRepo"],"body":"{\n    setLoading(true)\n    try {\n      const res = await classifyApi.fetchClassifyRepos()\n      if (Array.isArray(res)) {\n        setRepos(res)\n      } else if (res && typeof res === 'object' && 'repos' in res && Array.isArray((res as Record<string, unknown>).repos)) {\n        setRepos((res as Record<string, GithubRepo[]>).repos)\n      } else {\n        setRepos([])\n      }\n    } catch {\n      message.error('获取仓库列表失败')\n      setRepos([])\n    } finally {\n      setLoading(false)\n    }\n  }"}},{"name":"handleSelectAll","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":77,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"Arrow function handleSelectAll","context":"Defined in Classify.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["setSelectedIds","filteredRepos.map"],"usedImports":[],"body":"{\n    setSelectedIds(filteredRepos.map((r) => r.id))\n  }"}},{"name":"handleClearSelection","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":81,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"Arrow function handleClearSelection","context":"Defined in Classify.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["setSelectedIds"],"usedImports":[],"body":"{\n    setSelectedIds([])\n  }"}},{"name":"handleClassify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":85,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"Arrow function handleClassify","context":"Defined in Classify.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setClassifying","setResults","../api/classify#classifyApi.executeClassify","setResults","message.success","Object.keys","setTimeout","resultsRef.current.scrollIntoView","message.error","message.error","setClassifying"],"usedImports":["classifyApi"],"body":"{\n    if (selectedIds.length === 0) return\n    setClassifying(true)\n    setResults({})\n    try {\n      const res = await classifyApi.executeClassify(selectedIds, topN)\n      if (res.success && res.categories) {\n        setResults(res.categories)\n        message.success(`AI 分类完成，共 ${Object.keys(res.categories).length} 个分类`)\n        setTimeout(() => {\n          resultsRef.current?.scrollIntoView({ behavior: 'smooth', block: 'start' })\n        }, 150)\n      } else {\n        message.error('AI 分类失败，请稍后重试')\n      }\n    } catch {\n      message.error('AI 分类请求失败')\n    } finally {\n      setClassifying(false)\n    }\n  }"}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":113,"startLine":113,"endLine":118,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["a","GithubOutlined"],"isExported":false,"complexity":1,"body":"(\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 6 }} />\n          {record.fullName}\n        </a>\n      )","usedImports":["GithubRepo","GithubOutlined"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":135,"startLine":135,"endLine":136,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Tag"],"isExported":false,"complexity":2,"body":"lang ? <Tag color=\"blue\">{lang}</Tag> : <Tag color=\"default\">-</Tag>","usedImports":["Tag"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":239,"startLine":239,"endLine":271,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Col","Card","Text","Tag","div","a"],"isExported":false,"complexity":3,"body":"(\n              <Col xs={24} md={12} lg={8} key={category}>\n                <Card\n                  title={\n                    <Text strong style={{ fontSize: 15 }}>\n                      {category}\n                    </Text>\n                  }\n                  extra={<Tag>{repoList.length} 个仓库</Tag>}\n                  style={{ height: '100%' }}\n                >\n                  {repoList.map((r) => (\n                    <div key={r.id} style={{ padding: '4px 0' }}>\n                      <a\n                        href={r.htmlUrl}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        style={{ fontSize: 13 }}\n                      >\n                        {r.fullName}\n                      </a>\n                      {r.description && (\n                        <div style={{ color: '#888', fontSize: 12, marginTop: 2 }}>\n                          {r.description.length > 60\n                            ? r.description.slice(0, 60) + '...'\n                            : r.description}\n                        </div>\n                      )}\n                    </div>\n                  ))}\n                </Card>\n              </Col>\n            )","usedImports":["Col","Card","Tag"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":250,"startLine":250,"endLine":268,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["div","a"],"isExported":false,"complexity":2,"body":"(\n                    <div key={r.id} style={{ padding: '4px 0' }}>\n                      <a\n                        href={r.htmlUrl}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        style={{ fontSize: 13 }}\n                      >\n                        {r.fullName}\n                      </a>\n                      {r.description && (\n                        <div style={{ color: '#888', fontSize: 12, marginTop: 2 }}>\n                          {r.description.length > 60\n                            ? r.description.slice(0, 60) + '...'\n                            : r.description}\n                        </div>\n                      )}\n                    </div>\n                  )","usedImports":[],"calledBy":[]}},{"name":"formatDate","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":31,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"Function formatDate implementation","context":"Located in StarDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["Array.isArray","padStart","String","padStart","String","padStart","String","padStart","String","replace","dateStr.substring"],"usedImports":[],"body":"{\n  if (!dateStr) return '-'\n  if (Array.isArray(dateStr)) {\n    const [y, m, d, h = 0, min = 0] = dateStr\n    return `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')} ${String(h).padStart(2, '0')}:${String(min).padStart(2, '0')}`\n  }\n  return dateStr.substring(0, 19).replace('T', ' ')\n}"}},{"name":"parseTopics","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":40,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"Function parseTopics implementation","context":"Located in StarDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["JSON.parse"],"usedImports":[],"body":"{\n  if (!topics) return []\n  try {\n    return JSON.parse(topics)\n  } catch {\n    return []\n  }\n}"}},{"name":"StarDetail","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":49,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in StarDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useParams","useLocation","useNavigate","useState","useState","useState","useEffect","setLoading","setNotFound","Number","Promise.allSettled","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","topRes.value.find","recentRes.value.find","setRepo","setNotFound","setNotFound","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#fetchRepo","navigate","navigate","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#parseTopics","window.open","window.open","topics.map","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx#formatDate"],"usedImports":["useParams","useLocation","useNavigate","useState","GithubRepo","useEffect","statsApi","Spin","Button","ArrowLeftOutlined","Card","Empty","Avatar","Tag","Space","GithubOutlined","LinkOutlined","Row","Col","Statistic","StarFilled","ForkOutlined","EyeOutlined","BugOutlined","Descriptions"],"body":"{\n  const { id } = useParams<{ id: string }>()\n  const location = useLocation()\n  const navigate = useNavigate()\n\n  const [repo, setRepo] = useState<GithubRepo | null>(\n    (location.state as { repo?: GithubRepo })?.repo ?? null,\n  )\n  const [loading, setLoading] = useState(!repo)\n  const [notFound, setNotFound] = useState(false)\n\n  useEffect(() => {\n    if (repo) return\n\n    const fetchRepo = async () => {\n      setLoading(true)\n      setNotFound(false)\n      const numericId = Number(id)\n\n      try {\n        const [topRes, recentRes] = await Promise.allSettled([\n          statsApi.fetchTopStarredRepos(100),\n          statsApi.fetchRecentActiveRepos(100),\n        ])\n\n        let found: GithubRepo | undefined\n\n        if (topRes.status === 'fulfilled') {\n          found = topRes.value.find((r) => r.id === numericId)\n        }\n        if (!found && recentRes.status === 'fulfilled') {\n          found = recentRes.value.find((r) => r.id === numericId)\n        }\n\n        if (found) {\n          setRepo(found)\n        } else {\n          setNotFound(true)\n        }\n      } catch {\n        setNotFound(true)\n      } finally {\n        setLoading(false)\n      }\n    }\n\n    fetchRepo()\n  }, [id, repo])\n\n  const handleBack = () => {\n    if (window.history.length > 1) {\n      navigate(-1)\n    } else {\n      navigate('/')\n    }\n  }\n\n  if (loading) {\n    return (\n      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: 400 }}>\n        <Spin size=\"large\" tip=\"加载中...\" />\n      </div>\n    )\n  }\n\n  if (notFound || !repo) {\n    return (\n      <div>\n        <Button\n          icon={<ArrowLeftOutlined />}\n          onClick={handleBack}\n          style={{ marginBottom: 24 }}\n        >\n          返回\n        </Button>\n        <Card>\n          <Empty description=\"未找到该仓库数据\">\n            <Button type=\"primary\" onClick={() => navigate('/')}>\n              返回列表\n            </Button>\n          </Empty>\n        </Card>\n      </div>\n    )\n  }\n\n  const topics = parseTopics(repo.topics)\n\n  const statColStyle = { xs: 12 as const, sm: 12 as const, md: 6 as const }\n\n  return (\n    <div>\n      <Button\n        icon={<ArrowLeftOutlined />}\n        onClick={handleBack}\n        style={{ marginBottom: 20 }}\n      >\n        返回\n      </Button>\n\n      <Card style={{ marginBottom: 20 }}>\n        <div style={{ display: 'flex', alignItems: 'flex-start', gap: 16 }}>\n          <Avatar\n            src={repo.ownerAvatarUrl}\n            alt={repo.ownerName}\n            size={64}\n            style={{ flexShrink: 0 }}\n          />\n          <div style={{ flex: 1, minWidth: 0 }}>\n            <Title level={4} style={{ margin: 0, marginBottom: 4 }}>\n              {repo.fullName}\n            </Title>\n            <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n              <Text type=\"secondary\" style={{ fontSize: 14 }}>\n                {repo.ownerName}\n              </Text>\n              {repo.isFork && (\n                <Tag color=\"orange\" style={{ margin: 0 }}>\n                  已 Fork\n                </Tag>\n              )}\n              {repo.isArchived && (\n                <Tag color=\"default\" style={{ margin: 0 }}>\n                  已归档\n                </Tag>\n              )}\n            </div>\n            {repo.description && (\n              <Paragraph type=\"secondary\" style={{ marginBottom: 0 }}>\n                {repo.description}\n              </Paragraph>\n            )}\n          </div>\n          <Space>\n            <Button\n              type=\"primary\"\n              icon={<GithubOutlined />}\n              onClick={() => window.open(repo.htmlUrl, '_blank', 'noopener,noreferrer')}\n            >\n              在 GitHub 上查看\n            </Button>\n            {repo.homepage && (\n              <Button\n                icon={<LinkOutlined />}\n                onClick={() => window.open(repo.homepage!, '_blank', 'noopener,noreferrer')}\n              >\n                访问项目主页\n              </Button>\n            )}\n          </Space>\n        </div>\n      </Card>\n\n      <Card style={{ marginBottom: 20 }}>\n        <Row gutter={[16, 16]}>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Stars\"\n                value={repo.starsCount}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Forks\"\n                value={repo.forksCount}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Watchers\"\n                value={repo.watchersCount}\n                prefix={<EyeOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col {...statColStyle}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"Open Issues\"\n                value={repo.openIssuesCount}\n                prefix={<BugOutlined style={{ color: '#ff4d4f' }} />}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Card>\n\n      <Card title=\"详细信息\">\n        <Descriptions column={{ xs: 1, sm: 1, md: 2 }} bordered size=\"small\">\n          <Descriptions.Item label=\"编程语言\">\n            {repo.language ? (\n              <Tag color=\"blue\">{repo.language}</Tag>\n            ) : (\n              <Text type=\"secondary\">-</Text>\n            )}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"许可证\">\n            {repo.licenseName ? (\n              <Text>{repo.licenseName}</Text>\n            ) : (\n              <Text type=\"secondary\">-</Text>\n            )}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"主题标签\" span={2}>\n            {topics.length > 0 ? (\n              <Space size={[4, 4]} wrap>\n                {topics.map((topic) => (\n                  <Tag key={topic}>{topic}</Tag>\n                ))}\n              </Space>\n            ) : (\n              <Text type=\"secondary\">-</Text>\n            )}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"Star 时间\">\n            {formatDate(repo.starredAt)}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"仓库创建时间\">\n            {formatDate(repo.repoCreatedAt)}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"最后更新时间\">\n            {formatDate(repo.repoUpdatedAt)}\n          </Descriptions.Item>\n          <Descriptions.Item label=\"最后推送时间\">\n            {formatDate(repo.repoPushedAt)}\n          </Descriptions.Item>\n        </Descriptions>\n      </Card>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useParams","line":50,"customHook":true},{"name":"useLocation","line":51,"customHook":true},{"name":"useNavigate","line":52,"customHook":true},{"name":"useState","line":54,"customHook":false},{"name":"useState","line":57,"customHook":false},{"name":"useState","line":58,"customHook":false},{"name":"useEffect","line":60,"customHook":false}],"jsxElements":["div","Spin","Button","ArrowLeftOutlined","Card","Empty","Avatar","Title","Text","Tag","Paragraph","Space","GithubOutlined","LinkOutlined","Row","Col","Statistic","StarFilled","ForkOutlined","EyeOutlined","BugOutlined","Descriptions","Descriptions.Item"],"complexity":12}},{"name":"fetchRepo","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":63,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"Arrow function fetchRepo","context":"Defined in StarDetail.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","setNotFound","Number","Promise.allSettled","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","topRes.value.find","recentRes.value.find","setRepo","setNotFound","setNotFound","setLoading"],"usedImports":["statsApi","GithubRepo"],"body":"{\n      setLoading(true)\n      setNotFound(false)\n      const numericId = Number(id)\n\n      try {\n        const [topRes, recentRes] = await Promise.allSettled([\n          statsApi.fetchTopStarredRepos(100),\n          statsApi.fetchRecentActiveRepos(100),\n        ])\n\n        let found: GithubRepo | undefined\n\n        if (topRes.status === 'fulfilled') {\n          found = topRes.value.find((r) => r.id === numericId)\n        }\n        if (!found && recentRes.status === 'fulfilled') {\n          found = recentRes.value.find((r) => r.id === numericId)\n        }\n\n        if (found) {\n          setRepo(found)\n        } else {\n          setNotFound(true)\n        }\n      } catch {\n        setNotFound(true)\n      } finally {\n        setLoading(false)\n      }\n    }"}},{"name":"handleBack","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":98,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"Arrow function handleBack","context":"Defined in StarDetail.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["navigate","navigate"],"usedImports":[],"body":"{\n    if (window.history.length > 1) {\n      navigate(-1)\n    } else {\n      navigate('/')\n    }\n  }"}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarDetail.tsx","lineNumber":262,"startLine":262,"endLine":264,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in StarDetail.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Tag"],"isExported":false,"complexity":1,"body":"(\n                  <Tag key={topic}>{topic}</Tag>\n                )","usedImports":["Tag"],"calledBy":[]}},{"name":"formatDate","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":37,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Function formatDate implementation","context":"Located in StarList.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["Array.isArray","padStart","String","padStart","String","dateStr.substring","String"],"usedImports":[],"body":"{\n  if (!dateStr) return '-'\n  if (Array.isArray(dateStr)) {\n    const [y, m, d] = dateStr\n    return `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`\n  }\n  if (typeof dateStr === 'string') {\n    return dateStr.length >= 10 ? dateStr.substring(0, 10) : dateStr\n  }\n  return String(dateStr)\n}"}},{"name":"StarList","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":72,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in StarList.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useNavigate","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useEffect","Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","setOverview","setLanguageOptions","setInitialLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx#loadMeta","useEffect","setLoading","../api/stars#starsApi.fetchStarList","selectedLanguages.join","startMonth.format","endMonth.format","setPageResult","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx#loadPage","useCallback","setKeyword","setSelectedLanguages","setSortBy","setSortOrder","setDateField","setStartMonth","setEndMonth","setCurrentPage","useEffect","setCurrentPage","useCallback","../api/stars#starsApi.exportStarsUrls","selectedLanguages.join","startMonth.format","endMonth.format","window.URL.createObjectURL","document.createElement","format","dayjs","document.body.appendChild","a.click","document.body.removeChild","window.URL.revokeObjectURL","console.error","useCallback","navigate","useMemo","languageOptions.map","keyword.trim","setKeyword","setKeyword","setCurrentPage","setSelectedLanguages","setCurrentPage","includes","toLowerCase","input.toLowerCase","setSortBy","setCurrentPage","setSortOrder","setCurrentPage","setDateField","setCurrentPage","setStartMonth","setCurrentPage","setEndMonth","setCurrentPage","repos.map","handleCardClick","e.stopPropagation","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx#formatDate","PAGE_SIZE_OPTIONS.map","setCurrentPage","setPageSize"],"usedImports":["useNavigate","useState","PageResult","GithubRepo","OverviewStatsDTO","LanguageStatsDTO","dayjs","useEffect","statsApi","starsApi","useCallback","useMemo","Spin","Row","Col","Card","Statistic","GithubOutlined","StarFilled","ForkOutlined","Tag","Space","Input","SearchOutlined","Select","Button","ClearOutlined","DownloadOutlined","Collapse","CaretDownOutlined","DatePicker","Avatar","Empty","Pagination"],"body":"{\n  const navigate = useNavigate()\n\n  // 服务端分页数据\n  const [pageResult, setPageResult] = useState<PageResult<GithubRepo>>({\n    records: [],\n    total: 0,\n    size: 12,\n    current: 1,\n    pages: 0,\n  })\n  const [overview, setOverview] = useState<OverviewStatsDTO | null>(null)\n  const [languageOptions, setLanguageOptions] = useState<LanguageStatsDTO[]>([])\n  const [loading, setLoading] = useState(true)\n  const [initialLoading, setInitialLoading] = useState(true)\n\n  // 筛选参数\n  const [keyword, setKeyword] = useState('')\n  const [selectedLanguages, setSelectedLanguages] = useState<string[]>([])\n  const [sortBy, setSortBy] = useState('starred_at')\n  const [sortOrder, setSortOrder] = useState('desc')\n  const [dateField, setDateField] = useState<string | undefined>(undefined)\n  const [startMonth, setStartMonth] = useState<dayjs.Dayjs | null>(null)\n  const [endMonth, setEndMonth] = useState<dayjs.Dayjs | null>(null)\n\n  const [currentPage, setCurrentPage] = useState(1)\n  const [pageSize, setPageSize] = useState(12)\n\n  // 首次加载：获取概览统计 + 语言列表\n  useEffect(() => {\n    const loadMeta = async () => {\n      try {\n        const [overviewRes, langRes] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n        ])\n        if (overviewRes.status === 'fulfilled') {\n          setOverview(overviewRes.value)\n        }\n        if (langRes.status === 'fulfilled') {\n          setLanguageOptions(langRes.value)\n        }\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setInitialLoading(false)\n      }\n    }\n    loadMeta()\n  }, [])\n\n  // 服务端分页查询：筛选/排序/分页参数变化时重新请求\n  useEffect(() => {\n    const loadPage = async () => {\n      setLoading(true)\n      try {\n        const result = await starsApi.fetchStarList({\n          page: currentPage,\n          size: pageSize,\n          keyword: keyword || undefined,\n          language: selectedLanguages.length > 0 ? selectedLanguages.join(',') : undefined,\n          sortBy: sortBy || undefined,\n          sortOrder: sortOrder || undefined,\n          dateField: dateField || undefined,\n          startMonth: startMonth ? startMonth.format('YYYY-MM') : undefined,\n          endMonth: endMonth ? endMonth.format('YYYY-MM') : undefined,\n        })\n        setPageResult(result)\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setLoading(false)\n      }\n    }\n    loadPage()\n  }, [currentPage, pageSize, keyword, selectedLanguages, sortBy, sortOrder, dateField, startMonth, endMonth])\n\n  const handleClearFilters = useCallback(() => {\n    setKeyword('')\n    setSelectedLanguages([])\n    setSortBy('starred_at')\n    setSortOrder('desc')\n    setDateField(undefined)\n    setStartMonth(null)\n    setEndMonth(null)\n    setCurrentPage(1)\n  }, [])\n\n  // 筛选条件变化时回到第一页\n  useEffect(() => {\n    setCurrentPage(1)\n  }, [pageSize])\n\n  const handleExport = useCallback(async () => {\n    try {\n      const blob = await starsApi.exportStarsUrls({\n        keyword: keyword || undefined,\n        language: selectedLanguages.length > 0 ? selectedLanguages.join(',') : undefined,\n        sortBy: sortBy || undefined,\n        sortOrder: sortOrder || undefined,\n        dateField: dateField || undefined,\n        startMonth: startMonth ? startMonth.format('YYYY-MM') : undefined,\n        endMonth: endMonth ? endMonth.format('YYYY-MM') : undefined,\n      })\n      const url = window.URL.createObjectURL(blob)\n      const a = document.createElement('a')\n      a.href = url\n      a.download = `stars_export_${dayjs().format('YYYYMMDD_HHmmss')}.txt`\n      document.body.appendChild(a)\n      a.click()\n      document.body.removeChild(a)\n      window.URL.revokeObjectURL(url)\n    } catch {\n      console.error('导出失败')\n    }\n  }, [keyword, selectedLanguages, sortBy, sortOrder, dateField, startMonth, endMonth])\n\n  const handleCardClick = useCallback(\n    (repo: GithubRepo) => {\n      navigate(`/stars/${repo.id}`, { state: { repo } })\n    },\n    [navigate],\n  )\n\n  const languageSelectOptions = useMemo(\n    () =>\n      languageOptions.map((lang) => ({\n        label: `${lang.language} (${lang.count})`,\n        value: lang.language,\n      })),\n    [languageOptions],\n  )\n\n  const hasActiveFilters =\n    keyword.trim() !== '' ||\n    selectedLanguages.length > 0 ||\n    sortBy !== 'starred_at' ||\n    sortOrder !== 'desc' ||\n    dateField !== undefined ||\n    startMonth !== null ||\n    endMonth !== null\n\n  const { records: repos } = pageResult\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        Star 仓库列表\n      </Title>\n\n      <Spin spinning={initialLoading}>\n        <Row gutter={[16, 16]} style={{ marginBottom: 20 }}>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"总仓库数\"\n                value={overview?.totalRepos ?? 0}\n                prefix={<GithubOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"总 Star 数\"\n                value={overview?.totalStars ?? 0}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"总 Fork 数\"\n                value={overview?.totalForks ?? 0}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"语言种类\"\n                value={overview?.totalLanguages ?? 0}\n                prefix={<Tag color=\"purple\" style={{ marginRight: 0 }}>#</Tag>}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Spin>\n\n      <Card style={{ marginBottom: 20 }}>\n        <Space direction=\"vertical\" size=\"middle\" style={{ width: '100%' }}>\n          <Row gutter={[16, 16]} align=\"middle\">\n            <Col xs={24} sm={12} md={8} lg={6}>\n              <Input.Search\n                placeholder=\"搜索仓库名、描述、作者...\"\n                value={keyword}\n                onChange={(e) => setKeyword(e.target.value)}\n                onSearch={(val) => {\n                  setKeyword(val)\n                  setCurrentPage(1)\n                }}\n                allowClear\n                enterButton={<SearchOutlined />}\n              />\n            </Col>\n            <Col xs={24} sm={12} md={10} lg={7}>\n              <Select\n                mode=\"multiple\"\n                placeholder=\"筛选语言\"\n                value={selectedLanguages}\n                onChange={(vals) => {\n                  setSelectedLanguages(vals)\n                  setCurrentPage(1)\n                }}\n                options={languageSelectOptions}\n                allowClear\n                showSearch\n                maxTagCount={3}\n                filterOption={(input, option) =>\n                  (option?.label as string)?.toLowerCase().includes(input.toLowerCase())\n                }\n                style={{ width: '100%' }}\n              />\n            </Col>\n            <Col xs={12} sm={8} md={6} lg={4}>\n              <Select\n                placeholder=\"排序字段\"\n                value={sortBy}\n                onChange={(val) => {\n                  setSortBy(val)\n                  setCurrentPage(1)\n                }}\n                options={SORT_BY_OPTIONS}\n                style={{ width: '100%' }}\n              />\n            </Col>\n            <Col xs={12} sm={8} md={6} lg={3}>\n              <Select\n                placeholder=\"排序方向\"\n                value={sortOrder}\n                onChange={(val) => {\n                  setSortOrder(val)\n                  setCurrentPage(1)\n                }}\n                options={SORT_ORDER_OPTIONS}\n                style={{ width: '100%' }}\n              />\n            </Col>\n            <Col xs={24} sm={8} md={12} lg={4}>\n              <Space.Compact style={{ width: '100%' }}>\n                {hasActiveFilters && (\n                  <Button icon={<ClearOutlined />} onClick={handleClearFilters}>\n                    清除筛选\n                  </Button>\n                )}\n                <Button\n                  type=\"primary\"\n                  icon={<DownloadOutlined />}\n                  onClick={handleExport}\n                >\n                  导出链接\n                </Button>\n              </Space.Compact>\n            </Col>\n          </Row>\n\n          <Collapse\n            ghost\n            size=\"small\"\n            items={[\n              {\n                key: 'date-filter',\n                label: (\n                  <span style={{ fontSize: 13, color: '#666' }}>\n                    <CaretDownOutlined style={{ marginRight: 4 }} />\n                    时间筛选\n                  </span>\n                ),\n                children: (\n                  <Row gutter={[16, 12]} align=\"middle\">\n                    <Col xs={24} sm={8} md={6} lg={4}>\n                      <Select\n                        placeholder=\"时间字段\"\n                        value={dateField}\n                        onChange={(val) => {\n                          setDateField(val)\n                          setCurrentPage(1)\n                        }}\n                        allowClear\n                        options={DATE_FIELD_OPTIONS}\n                        style={{ width: '100%' }}\n                      />\n                    </Col>\n                    <Col xs={12} sm={8} md={6} lg={4}>\n                      <DatePicker\n                        picker=\"month\"\n                        placeholder=\"起始月份\"\n                        value={startMonth}\n                        onChange={(val) => {\n                          setStartMonth(val)\n                          setCurrentPage(1)\n                        }}\n                        disabled={!dateField}\n                        style={{ width: '100%' }}\n                      />\n                    </Col>\n                    <Col xs={12} sm={8} md={6} lg={4}>\n                      <DatePicker\n                        picker=\"month\"\n                        placeholder=\"结束月份\"\n                        value={endMonth}\n                        onChange={(val) => {\n                          setEndMonth(val)\n                          setCurrentPage(1)\n                        }}\n                        disabled={!dateField}\n                        style={{ width: '100%' }}\n                      />\n                    </Col>\n                  </Row>\n                ),\n              },\n            ]}\n          />\n        </Space>\n      </Card>\n\n      <Spin spinning={loading}>\n        {repos.length > 0 ? (\n          <Row gutter={[16, 16]}>\n            {repos.map((repo) => (\n              <Col key={repo.id} xs={24} sm={12} md={8} lg={6}>\n                <Card\n                  hoverable\n                  style={{ height: '100%', cursor: 'pointer' }}\n                  onClick={() => handleCardClick(repo)}\n                  styles={{ body: { padding: 16 } }}\n                >\n                  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, marginBottom: 10 }}>\n                    <Avatar\n                      src={repo.ownerAvatarUrl}\n                      alt={repo.ownerName}\n                      size={40}\n                      style={{ flexShrink: 0 }}\n                    />\n                    <div style={{ minWidth: 0, flex: 1 }}>\n                      <Text\n                        strong\n                        style={{ fontSize: 14, display: 'block', lineHeight: '20px' }}\n                        ellipsis\n                      >\n                        <a\n                          onClick={(e) => {\n                            e.stopPropagation()\n                            navigate(`/stars/${repo.id}`, { state: { repo } })\n                          }}\n                          style={{ color: '#1677ff' }}\n                        >\n                          {repo.repoName}\n                        </a>\n                      </Text>\n                      <Text type=\"secondary\" style={{ fontSize: 12 }} ellipsis>\n                        {repo.ownerName}\n                      </Text>\n                    </div>\n                  </div>\n                  {repo.description && (\n                    <Paragraph\n                      type=\"secondary\"\n                      ellipsis={{ rows: 2 }}\n                      style={{ marginBottom: 10, fontSize: 12, minHeight: 36 }}\n                    >\n                      {repo.description}\n                    </Paragraph>\n                  )}\n                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n                    {repo.language && (\n                      <Tag color=\"blue\" style={{ margin: 0 }}>\n                        {repo.language}\n                      </Tag>\n                    )}\n                    <Space size={4}>\n                      <StarFilled style={{ color: '#faad14', fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.starsCount}</Text>\n                    </Space>\n                    <Space size={4}>\n                      <ForkOutlined style={{ fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.forksCount}</Text>\n                    </Space>\n                  </div>\n                  <Text type=\"secondary\" style={{ fontSize: 11 }}>\n                    Star 于 {formatDate(repo.starredAt)}\n                  </Text>\n                </Card>\n              </Col>\n            ))}\n          </Row>\n        ) : (\n          <Card>\n            <Empty\n              description={\n                loading\n                  ? '加载中...'\n                  : pageResult.total === 0\n                    ? '暂无仓库数据，请先同步'\n                    : '筛选无结果，请尝试调整筛选条件'\n              }\n            >\n              {hasActiveFilters && (\n                <Button type=\"primary\" onClick={handleClearFilters}>\n                  清除所有筛选\n                </Button>\n              )}\n            </Empty>\n          </Card>\n        )}\n\n        {pageResult.total > pageSize && (\n          <div style={{ marginTop: 20, display: 'flex', justifyContent: 'center' }}>\n            <Pagination\n              current={currentPage}\n              pageSize={pageSize}\n              total={pageResult.total}\n              showSizeChanger\n              pageSizeOptions={PAGE_SIZE_OPTIONS.map(String)}\n              showQuickJumper\n              showTotal={(total) => `共 ${total} 条 / ${pageResult.pages} 页`}\n              onChange={(page, size) => {\n                setCurrentPage(page)\n                if (size !== pageSize) {\n                  setPageSize(size)\n                }\n              }}\n            />\n          </div>\n        )}\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useNavigate","line":73,"customHook":true},{"name":"useState","line":76,"customHook":false},{"name":"useState","line":83,"customHook":false},{"name":"useState","line":84,"customHook":false},{"name":"useState","line":85,"customHook":false},{"name":"useState","line":86,"customHook":false},{"name":"useState","line":89,"customHook":false},{"name":"useState","line":90,"customHook":false},{"name":"useState","line":91,"customHook":false},{"name":"useState","line":92,"customHook":false},{"name":"useState","line":93,"customHook":false},{"name":"useState","line":94,"customHook":false},{"name":"useState","line":95,"customHook":false},{"name":"useState","line":97,"customHook":false},{"name":"useState","line":98,"customHook":false},{"name":"useEffect","line":101,"customHook":false},{"name":"useEffect","line":124,"customHook":false},{"name":"useCallback","line":149,"customHook":false},{"name":"useEffect","line":161,"customHook":false},{"name":"useCallback","line":165,"customHook":false},{"name":"useCallback","line":189,"customHook":false},{"name":"useMemo","line":196,"customHook":false}],"jsxElements":["div","Title","Spin","Row","Col","Card","Statistic","GithubOutlined","StarFilled","ForkOutlined","Tag","Space","Input.Search","SearchOutlined","Select","Space.Compact","Button","ClearOutlined","DownloadOutlined","Collapse","span","CaretDownOutlined","DatePicker","Avatar","Text","a","Paragraph","Empty","Pagination"],"complexity":16}},{"name":"loadMeta","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":102,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function loadMeta","context":"Defined in StarList.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","setOverview","setLanguageOptions","setInitialLoading"],"usedImports":["statsApi"],"body":"{\n      try {\n        const [overviewRes, langRes] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n        ])\n        if (overviewRes.status === 'fulfilled') {\n          setOverview(overviewRes.value)\n        }\n        if (langRes.status === 'fulfilled') {\n          setLanguageOptions(langRes.value)\n        }\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setInitialLoading(false)\n      }\n    }"}},{"name":"loadPage","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":125,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function loadPage","context":"Defined in StarList.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","../api/stars#starsApi.fetchStarList","selectedLanguages.join","startMonth.format","endMonth.format","setPageResult","setLoading"],"usedImports":["starsApi"],"body":"{\n      setLoading(true)\n      try {\n        const result = await starsApi.fetchStarList({\n          page: currentPage,\n          size: pageSize,\n          keyword: keyword || undefined,\n          language: selectedLanguages.length > 0 ? selectedLanguages.join(',') : undefined,\n          sortBy: sortBy || undefined,\n          sortOrder: sortOrder || undefined,\n          dateField: dateField || undefined,\n          startMonth: startMonth ? startMonth.format('YYYY-MM') : undefined,\n          endMonth: endMonth ? endMonth.format('YYYY-MM') : undefined,\n        })\n        setPageResult(result)\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setLoading(false)\n      }\n    }"}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":404,"startLine":404,"endLine":469,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in StarList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Col","Card","div","Avatar","Text","a","Paragraph","Tag","Space","StarFilled","ForkOutlined"],"isExported":false,"complexity":1,"body":"(\n              <Col key={repo.id} xs={24} sm={12} md={8} lg={6}>\n                <Card\n                  hoverable\n                  style={{ height: '100%', cursor: 'pointer' }}\n                  onClick={() => handleCardClick(repo)}\n                  styles={{ body: { padding: 16 } }}\n                >\n                  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, marginBottom: 10 }}>\n                    <Avatar\n                      src={repo.ownerAvatarUrl}\n                      alt={repo.ownerName}\n                      size={40}\n                      style={{ flexShrink: 0 }}\n                    />\n                    <div style={{ minWidth: 0, flex: 1 }}>\n                      <Text\n                        strong\n                        style={{ fontSize: 14, display: 'block', lineHeight: '20px' }}\n                        ellipsis\n                      >\n                        <a\n                          onClick={(e) => {\n                            e.stopPropagation()\n                            navigate(`/stars/${repo.id}`, { state: { repo } })\n                          }}\n                          style={{ color: '#1677ff' }}\n                        >\n                          {repo.repoName}\n                        </a>\n                      </Text>\n                      <Text type=\"secondary\" style={{ fontSize: 12 }} ellipsis>\n                        {repo.ownerName}\n                      </Text>\n                    </div>\n                  </div>\n                  {repo.description && (\n                    <Paragraph\n                      type=\"secondary\"\n                      ellipsis={{ rows: 2 }}\n                      style={{ marginBottom: 10, fontSize: 12, minHeight: 36 }}\n                    >\n                      {repo.description}\n                    </Paragraph>\n                  )}\n                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n                    {repo.language && (\n                      <Tag color=\"blue\" style={{ margin: 0 }}>\n                        {repo.language}\n                      </Tag>\n                    )}\n                    <Space size={4}>\n                      <StarFilled style={{ color: '#faad14', fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.starsCount}</Text>\n                    </Space>\n                    <Space size={4}>\n                      <ForkOutlined style={{ fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.forksCount}</Text>\n                    </Space>\n                  </div>\n                  <Text type=\"secondary\" style={{ fontSize: 11 }}>\n                    Star 于 {formatDate(repo.starredAt)}\n                  </Text>\n                </Card>\n              </Col>\n            )","usedImports":["Col","Card","Avatar","Tag","Space","StarFilled","ForkOutlined"],"calledBy":[]}},{"name":"formatNumber","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":52,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Function formatNumber implementation","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["toFixed","toFixed","String"],"usedImports":[],"body":"{\n  if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M'\n  if (n >= 1000) return (n / 1000).toFixed(1) + 'K'\n  return String(n)\n}"}},{"name":"formatDate","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":58,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Function formatDate implementation","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["Array.isArray","padStart","String","padStart","String","dateStr.substring","String"],"usedImports":[],"body":"{\n  if (!dateStr) return '-'\n  if (Array.isArray(dateStr)) {\n    const [y, m, d] = dateStr\n    return `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`\n  }\n  if (typeof dateStr === 'string') {\n    return dateStr.length >= 10 ? dateStr.substring(0, 10) : dateStr\n  }\n  return String(dateStr)\n}"}},{"name":"Stats","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":70,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useState","useState","useState","useState","useState","useState","useState","useEffect","setLoading","Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","../api/stats#statsApi.fetchOwnerStats","../api/stats#statsApi.fetchTimelineStats","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","setOverview","setLanguages","setOwners","setTimeline","setTopRepos","setRecentRepos","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#fetchAll","languages.slice","reduce","languages.slice","concat","langTop.map","concat","langTop.map","CHART_COLORS.slice","owners.map","owners.map","timeline.map","timeline.map","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatDate","da.localeCompare","topRepos.map","recentRepos.map","languages.reduce","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","toFixed"],"usedImports":["useState","OverviewStatsDTO","LanguageStatsDTO","OwnerStatsDTO","TimelineStatsDTO","GithubRepo","useEffect","statsApi","GithubOutlined","Tag","Spin","Row","Col","Card","Statistic","StarFilled","ForkOutlined","Doughnut","Bar","Line","Table"],"body":"{\n  const [overview, setOverview] = useState<OverviewStatsDTO | null>(null)\n  const [languages, setLanguages] = useState<LanguageStatsDTO[]>([])\n  const [owners, setOwners] = useState<OwnerStatsDTO[]>([])\n  const [timeline, setTimeline] = useState<TimelineStatsDTO[]>([])\n  const [topRepos, setTopRepos] = useState<GithubRepo[]>([])\n  const [recentRepos, setRecentRepos] = useState<GithubRepo[]>([])\n  const [loading, setLoading] = useState(true)\n\n  useEffect(() => {\n    const fetchAll = async () => {\n      setLoading(true)\n      try {\n        const [\n          overviewRes,\n          languagesRes,\n          ownersRes,\n          timelineRes,\n          topReposRes,\n          recentReposRes,\n        ] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n          statsApi.fetchOwnerStats(TOP_N_OWNERS),\n          statsApi.fetchTimelineStats(),\n          statsApi.fetchTopStarredRepos(TOP_N_REPOS),\n          statsApi.fetchRecentActiveRepos(TOP_N_REPOS),\n        ])\n\n        if (overviewRes.status === 'fulfilled') setOverview(overviewRes.value)\n        if (languagesRes.status === 'fulfilled') setLanguages(languagesRes.value)\n        if (ownersRes.status === 'fulfilled') setOwners(ownersRes.value)\n        if (timelineRes.status === 'fulfilled') setTimeline(timelineRes.value)\n        if (topReposRes.status === 'fulfilled') setTopRepos(topReposRes.value)\n        if (recentReposRes.status === 'fulfilled') setRecentRepos(recentReposRes.value)\n      } finally {\n        setLoading(false)\n      }\n    }\n    fetchAll()\n  }, [])\n\n  const langTop = languages.slice(0, TOP_N_LANGUAGES)\n  const langOthers = languages.slice(TOP_N_LANGUAGES).reduce((sum, l) => sum + l.count, 0)\n\n  const languageDoughnutData = {\n    labels: langTop.map((l) => l.language).concat(langOthers > 0 ? ['其他'] : []),\n    datasets: [\n      {\n        data: langTop.map((l) => l.count).concat(langOthers > 0 ? [langOthers] : []),\n        backgroundColor: CHART_COLORS.slice(0, langTop.length + (langOthers > 0 ? 1 : 0)),\n        borderWidth: 1,\n      },\n    ],\n  }\n\n  const ownerBarData = {\n    labels: owners.map((o) => o.ownerName),\n    datasets: [\n      {\n        label: '仓库数量',\n        data: owners.map((o) => o.count),\n        backgroundColor: '#36A2EB',\n        borderRadius: 4,\n      },\n    ],\n  }\n\n  const timelineLineData = {\n    labels: timeline.map((t) => t.month),\n    datasets: [\n      {\n        label: 'Star 数量',\n        data: timeline.map((t) => t.count),\n        fill: true,\n        tension: 0.3,\n        borderColor: '#FF6384',\n        backgroundColor: 'rgba(255, 99, 132, 0.15)',\n        pointRadius: 3,\n        pointHoverRadius: 6,\n      },\n    ],\n  }\n\n  const topStarredColumns = [\n    { title: '排名', dataIndex: 'rank', key: 'rank', width: 60, align: 'center' as const },\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 100,\n      render: (lang: string | null) => (lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>),\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n      sorter: (a: { starsCount: number }, b: { starsCount: number }) => a.starsCount - b.starsCount,\n    },\n    {\n      title: 'Fork数',\n      dataIndex: 'forksCount',\n      key: 'forksCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n    },\n  ]\n\n  const recentActiveColumns = [\n    { title: '排名', dataIndex: 'rank', key: 'rank', width: 60, align: 'center' as const },\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 100,\n      render: (lang: string | null) => (lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>),\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n    },\n    {\n      title: '最近更新时间',\n      dataIndex: 'repoUpdatedAt',\n      key: 'repoUpdatedAt',\n      width: 130,\n      render: (v: string | null) => formatDate(v),\n      sorter: (a: { repoUpdatedAt: string | null }, b: { repoUpdatedAt: string | null }) => {\n        const da = a.repoUpdatedAt ?? ''\n        const db = b.repoUpdatedAt ?? ''\n        return da.localeCompare(db)\n      },\n    },\n  ]\n\n  const topStarredSource = topRepos.map((r, i) => ({ ...r, key: r.id, rank: i + 1 }))\n  const recentActiveSource = recentRepos.map((r, i) => ({ ...r, key: r.id, rank: i + 1 }))\n\n  const totalLanguageCount = languages.reduce((sum, l) => sum + l.count, 0)\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        数据统计\n      </Title>\n\n      <Spin spinning={loading}>\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={12} sm={8} md={4}>\n            <Card>\n              <Statistic\n                title=\"总仓库数\"\n                value={overview?.totalRepos ?? 0}\n                prefix={<GithubOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"总 Star 数\"\n                value={overview?.totalStars ?? 0}\n                formatter={(value) => formatNumber(value as number)}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"总 Fork 数\"\n                value={overview?.totalForks ?? 0}\n                formatter={(value) => formatNumber(value as number)}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"语言种类数\"\n                value={overview?.totalLanguages ?? 0}\n                prefix={<Tag color=\"purple\" style={{ marginRight: 0 }}>#</Tag>}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"作者数\"\n                value={overview?.totalOwners ?? 0}\n                prefix={<StarFilled style={{ color: '#eb2f96' }} />}\n              />\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={24} lg={12}>\n            <Card title=\"语言分布\" style={{ height: '100%' }}>\n              {languages.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Doughnut\n                    data={languageDoughnutData}\n                    options={{\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      plugins: {\n                        legend: {\n                          position: 'right' as const,\n                          labels: { boxWidth: 12, padding: 8, font: { size: 11 } },\n                        },\n                        tooltip: {\n                          callbacks: {\n                            label: (ctx: { label: string; parsed: number }) => {\n                              const pct = totalLanguageCount > 0\n                                ? ((ctx.parsed / totalLanguageCount) * 100).toFixed(1)\n                                : '0'\n                              return `${ctx.label}: ${ctx.parsed} (${pct}%)`\n                            },\n                          },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无语言数据\n                </div>\n              )}\n            </Card>\n          </Col>\n          <Col xs={24} lg={12}>\n            <Card title=\"作者排行\" style={{ height: '100%' }}>\n              {owners.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Bar\n                    data={ownerBarData}\n                    options={{\n                      indexAxis: 'y' as const,\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      plugins: {\n                        legend: { display: false },\n                      },\n                      scales: {\n                        x: {\n                          title: { display: true, text: '仓库数量' },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无作者数据\n                </div>\n              )}\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col span={24}>\n            <Card title=\"Star 时间趋势\">\n              {timeline.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Line\n                    data={timelineLineData}\n                    options={{\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      interaction: {\n                        intersect: false,\n                        mode: 'index' as const,\n                      },\n                      plugins: {\n                        legend: {\n                          position: 'top' as const,\n                        },\n                      },\n                      scales: {\n                        y: {\n                          title: { display: true, text: 'Star 数量' },\n                          beginAtZero: true,\n                        },\n                        x: {\n                          title: { display: true, text: '月份' },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无时间线数据\n                </div>\n              )}\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]}>\n          <Col xs={24} lg={12}>\n            <Card title=\"最受欢迎仓库 Top 10\">\n              <Table\n                columns={topStarredColumns}\n                dataSource={topStarredSource}\n                pagination={false}\n                size=\"small\"\n                scroll={{ x: 500 }}\n              />\n            </Card>\n          </Col>\n          <Col xs={24} lg={12}>\n            <Card title=\"最近活跃仓库 Top 10\">\n              <Table\n                columns={recentActiveColumns}\n                dataSource={recentActiveSource}\n                pagination={false}\n                size=\"small\"\n                scroll={{ x: 520 }}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":71,"customHook":false},{"name":"useState","line":72,"customHook":false},{"name":"useState","line":73,"customHook":false},{"name":"useState","line":74,"customHook":false},{"name":"useState","line":75,"customHook":false},{"name":"useState","line":76,"customHook":false},{"name":"useState","line":77,"customHook":false},{"name":"useEffect","line":79,"customHook":false}],"jsxElements":["a","GithubOutlined","Tag","div","Title","Spin","Row","Col","Card","Statistic","StarFilled","ForkOutlined","Doughnut","Bar","Line","Table"],"complexity":24}},{"name":"fetchAll","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":80,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Arrow function fetchAll","context":"Defined in Stats.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","../api/stats#statsApi.fetchOwnerStats","../api/stats#statsApi.fetchTimelineStats","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","setOverview","setLanguages","setOwners","setTimeline","setTopRepos","setRecentRepos","setLoading"],"usedImports":["statsApi"],"body":"{\n      setLoading(true)\n      try {\n        const [\n          overviewRes,\n          languagesRes,\n          ownersRes,\n          timelineRes,\n          topReposRes,\n          recentReposRes,\n        ] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n          statsApi.fetchOwnerStats(TOP_N_OWNERS),\n          statsApi.fetchTimelineStats(),\n          statsApi.fetchTopStarredRepos(TOP_N_REPOS),\n          statsApi.fetchRecentActiveRepos(TOP_N_REPOS),\n        ])\n\n        if (overviewRes.status === 'fulfilled') setOverview(overviewRes.value)\n        if (languagesRes.status === 'fulfilled') setLanguages(languagesRes.value)\n        if (ownersRes.status === 'fulfilled') setOwners(ownersRes.value)\n        if (timelineRes.status === 'fulfilled') setTimeline(timelineRes.value)\n        if (topReposRes.status === 'fulfilled') setTopRepos(topReposRes.value)\n        if (recentReposRes.status === 'fulfilled') setRecentRepos(recentReposRes.value)\n      } finally {\n        setLoading(false)\n      }\n    }"}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":160,"startLine":160,"endLine":165,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["a","GithubOutlined"],"isExported":false,"complexity":1,"body":"(\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      )","usedImports":["GithubRepo","GithubOutlined"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":172,"startLine":172,"endLine":172,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Tag"],"isExported":false,"complexity":2,"body":"(lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>)","usedImports":["Tag"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":199,"startLine":199,"endLine":204,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["a","GithubOutlined"],"isExported":false,"complexity":1,"body":"(\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      )","usedImports":["GithubRepo","GithubOutlined"],"calledBy":[]}},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":211,"startLine":211,"endLine":211,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Tag"],"isExported":false,"complexity":2,"body":"(lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>)","usedImports":["Tag"],"calledBy":[]}},{"name":"formatDateTime","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Sync.tsx","lineNumber":19,"language":"typescript","dependencies":["react","antd","@ant-design/icons","dayjs"],"purpose":"Function formatDateTime implementation","context":"Located in Sync.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["Array.isArray","padStart","String","padStart","String","padStart","String","padStart","String","padStart","String","format","dayjs"],"usedImports":["dayjs"],"body":"{\n  if (!value) return '-'\n  if (Array.isArray(value)) {\n    const [y, m, d, h = 0, min = 0, s = 0] = value\n    return `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')} ${String(h).padStart(2, '0')}:${String(min).padStart(2, '0')}:${String(s).padStart(2, '0')}`\n  }\n  if (typeof value === 'string') {\n    return dayjs(value).format('YYYY-MM-DD HH:mm:ss')\n  }\n  return '-'\n}"}},{"name":"Sync","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Sync.tsx","lineNumber":31,"language":"typescript","dependencies":["react","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in Sync.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useState","useState","useState","useState","useState","useState","useState","useState","useRef","useRef","useRef","useEffect","useEffect","useCallback","clearInterval","setIsPolling","useCallback","setIsPolling","setInterval","../api/sync#syncApi.fetchSyncStatus","setStatus","stopPolling","../api/sync#syncApi.fetchSyncLogs","setLogs","setTotal","useCallback","../api/sync#syncApi.fetchSyncLogs","setLogs","setTotal","setSyncError","setIsPolling","../api/sync#syncApi.triggerManualSync","setSyncError","setIsPolling","startPolling","setSyncError","setIsPolling","useEffect","setLoading","../api/sync#syncApi.fetchSyncStatus","setStatus","startPolling","../api/sync#syncApi.fetchSyncLogs","setLogs","setTotal","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Sync.tsx#init","clearInterval","useEffect","fetchLogs","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Sync.tsx#formatDateTime","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Sync.tsx#formatDateTime","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Sync.tsx#formatDateTime","setSyncError","setPageNum","setPageSize"],"usedImports":["useState","SyncStatus","SyncLog","useRef","useEffect","useCallback","syncApi","Tag","Spin","Row","Col","Card","Statistic","CheckCircleOutlined","SyncOutlined","ClockCircleOutlined","Button","Alert","Table"],"body":"{\n  const [status, setStatus] = useState<SyncStatus | null>(null)\n  const [logs, setLogs] = useState<SyncLog[]>([])\n  const [total, setTotal] = useState(0)\n  const [loading, setLoading] = useState(true)\n  const [isPolling, setIsPolling] = useState(false)\n  const [pageNum, setPageNum] = useState(1)\n  const [pageSize, setPageSize] = useState(10)\n  const [syncError, setSyncError] = useState<string | null>(null)\n\n  const timerRef = useRef<ReturnType<typeof setInterval> | null>(null)\n  const pageNumRef = useRef(pageNum)\n  const pageSizeRef = useRef(pageSize)\n\n  useEffect(() => { pageNumRef.current = pageNum }, [pageNum])\n  useEffect(() => { pageSizeRef.current = pageSize }, [pageSize])\n\n  const stopPolling = useCallback(() => {\n    if (timerRef.current) {\n      clearInterval(timerRef.current)\n      timerRef.current = null\n    }\n    setIsPolling(false)\n  }, [])\n\n  const startPolling = useCallback(() => {\n    if (timerRef.current) return\n    setIsPolling(true)\n    timerRef.current = setInterval(async () => {\n      try {\n        const s = await syncApi.fetchSyncStatus()\n        setStatus(s)\n        if (!s.syncing) {\n          stopPolling()\n          try {\n            const res = await syncApi.fetchSyncLogs(pageNumRef.current, pageSizeRef.current)\n            setLogs(res.records)\n            setTotal(res.total)\n          } catch { /* ignore */ }\n        }\n      } catch { /* keep polling */ }\n    }, 2000)\n  }, [stopPolling])\n\n  const fetchLogs = useCallback(async (page: number, size: number) => {\n    try {\n      const res = await syncApi.fetchSyncLogs(page, size)\n      setLogs(res.records)\n      setTotal(res.total)\n    } catch { /* ignore */ }\n  }, [])\n\n  const handleSync = async () => {\n    setSyncError(null)\n    setIsPolling(true)\n    try {\n      const res = await syncApi.triggerManualSync()\n      if (!res.success) {\n        setSyncError(res.message || '同步触发失败')\n        setIsPolling(false)\n        return\n      }\n      startPolling()\n    } catch {\n      setSyncError('同步请求失败，请稍后重试')\n      setIsPolling(false)\n    }\n  }\n\n  useEffect(() => {\n    const init = async () => {\n      setLoading(true)\n      try {\n        const s = await syncApi.fetchSyncStatus()\n        setStatus(s)\n        if (s.syncing) {\n          startPolling()\n        }\n      } catch { /* ignore */ }\n      try {\n        const res = await syncApi.fetchSyncLogs(1, 10)\n        setLogs(res.records)\n        setTotal(res.total)\n      } catch { /* ignore */ }\n      setLoading(false)\n    }\n    init()\n\n    return () => {\n      if (timerRef.current) {\n        clearInterval(timerRef.current)\n        timerRef.current = null\n      }\n    }\n  }, [startPolling])\n\n  useEffect(() => {\n    fetchLogs(pageNum, pageSize)\n  }, [pageNum, pageSize, fetchLogs])\n\n  const columns = [\n    { title: 'ID', dataIndex: 'id', key: 'id', width: 60 },\n    {\n      title: '同步类型',\n      dataIndex: 'syncType',\n      key: 'syncType',\n      width: 100,\n      render: (v: string) => (\n        <Tag>{v === 'manual' ? '手动' : v === 'scheduled' ? '定时' : v}</Tag>\n      ),\n    },\n    {\n      title: '状态',\n      dataIndex: 'status',\n      key: 'status',\n      width: 100,\n      render: (v: string) => (\n        <Tag color={statusColorMap[v] || 'default'}>{v}</Tag>\n      ),\n    },\n    { title: '总数', dataIndex: 'totalCount', key: 'totalCount', width: 80, align: 'right' as const },\n    { title: '已同步数', dataIndex: 'syncedCount', key: 'syncedCount', width: 100, align: 'right' as const },\n    {\n      title: '开始时间',\n      dataIndex: 'startedAt',\n      key: 'startedAt',\n      width: 170,\n      render: (v: string | null) => formatDateTime(v),\n    },\n    {\n      title: '完成时间',\n      dataIndex: 'finishedAt',\n      key: 'finishedAt',\n      width: 170,\n      render: (v: string | null) => formatDateTime(v),\n    },\n    {\n      title: '错误信息',\n      dataIndex: 'errorMessage',\n      key: 'errorMessage',\n      width: 200,\n      ellipsis: true,\n      render: (v: string | null) => v ? <span style={{ color: '#ff4d4f' }}>{v}</span> : '-',\n    },\n  ]\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        同步管理\n      </Title>\n\n      <Spin spinning={loading}>\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={12} sm={6}>\n            <Card>\n              <Statistic\n                title=\"仓库总数\"\n                value={status?.totalRepos ?? 0}\n                prefix={<CheckCircleOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card>\n              <Statistic\n                title=\"上次同步数\"\n                value={status?.lastSyncCount ?? 0}\n                prefix={<SyncOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card>\n              <Statistic\n                title=\"上次同步时间\"\n                value={formatDateTime(status?.lastSyncTime ?? null)}\n                valueStyle={{ fontSize: 14 }}\n                prefix={<ClockCircleOutlined style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card>\n              <Statistic\n                title=\"当前状态\"\n                value=\" \"\n                valueStyle={{ fontSize: 0 }}\n                formatter={() => (\n                  <Tag\n                    color={\n                      status?.syncing\n                        ? 'processing'\n                        : statusColorMap[status?.status ?? ''] || 'default'\n                    }\n                    style={{ fontSize: 14, padding: '2px 12px' }}\n                  >\n                    {status?.syncing ? '同步中' : (status?.status || '空闲')}\n                  </Tag>\n                )}\n              />\n            </Card>\n          </Col>\n        </Row>\n\n        <Card style={{ marginBottom: 24 }}>\n          <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>\n            <Button\n              type=\"primary\"\n              icon={<SyncOutlined spin={isPolling} />}\n              onClick={handleSync}\n              loading={isPolling}\n            >\n              立即同步\n            </Button>\n            {isPolling && (\n              <span style={{ color: '#1677ff' }}>正在同步中，请稍候...</span>\n            )}\n          </div>\n          {syncError && (\n            <Alert\n              type=\"error\"\n              message={syncError}\n              closable\n              onClose={() => setSyncError(null)}\n              style={{ marginTop: 12 }}\n            />\n          )}\n          {status?.syncing && (\n            <Alert\n              type=\"info\"\n              message=\"系统正在执行同步任务，数据持续更新中...\"\n              showIcon\n              style={{ marginTop: 12 }}\n            />\n          )}\n        </Card>\n\n        <Card title=\"同步日志\">\n          <Table\n            columns={columns}\n            dataSource={logs}\n            rowKey=\"id\"\n            pagination={{\n              current: pageNum,\n              pageSize: pageSize,\n              total: total,\n              showSizeChanger: true,\n              pageSizeOptions: ['10', '20', '50'],\n              showTotal: (t: number) => `共 ${t} 条`,\n            }}\n            onChange={(pagination) => {\n              if (pagination.current) setPageNum(pagination.current)\n              if (pagination.pageSize) setPageSize(pagination.pageSize)\n            }}\n            scroll={{ x: 980 }}\n            size=\"small\"\n          />\n        </Card>\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":32,"customHook":false},{"name":"useState","line":33,"customHook":false},{"name":"useState","line":34,"customHook":false},{"name":"useState","line":35,"customHook":false},{"name":"useState","line":36,"customHook":false},{"name":"useState","line":37,"customHook":false},{"name":"useState","line":38,"customHook":false},{"name":"useState","line":39,"customHook":false},{"name":"useRef","line":41,"customHook":false},{"name":"useRef","line":42,"customHook":false},{"name":"useRef","line":43,"customHook":false},{"name":"useEffect","line":45,"customHook":false},{"name":"useEffect","line":46,"customHook":false},{"name":"useCallback","line":48,"customHook":false},{"name":"useCallback","line":56,"customHook":false},{"name":"useCallback","line":75,"customHook":false},{"name":"useEffect","line":100,"customHook":false},{"name":"useEffect","line":127,"customHook":false}],"jsxElements":["Tag","span","div","Title","Spin","Row","Col","Card","Statistic","CheckCircleOutlined","SyncOutlined","ClockCircleOutline