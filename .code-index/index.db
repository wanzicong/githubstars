ist.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useNavigate","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useState","useEffect","Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","setOverview","setLanguageOptions","setInitialLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx#loadMeta","useEffect","setLoading","../api/stars#starsApi.fetchStarList","selectedLanguages.join","startMonth.format","endMonth.format","setPageResult","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx#loadPage","useCallback","setKeyword","setSelectedLanguages","setSortBy","setSortOrder","setDateField","setStartMonth","setEndMonth","setCurrentPage","useEffect","setCurrentPage","useCallback","../api/stars#starsApi.exportStarsUrls","selectedLanguages.join","startMonth.format","endMonth.format","window.URL.createObjectURL","document.createElement","format","dayjs","document.body.appendChild","a.click","document.body.removeChild","window.URL.revokeObjectURL","console.error","useCallback","navigate","useMemo","languageOptions.map","keyword.trim","setKeyword","setKeyword","setCurrentPage","setSelectedLanguages","setCurrentPage","includes","toLowerCase","input.toLowerCase","setSortBy","setCurrentPage","setSortOrder","setCurrentPage","setDateField","setCurrentPage","setStartMonth","setCurrentPage","setEndMonth","setCurrentPage","repos.map","handleCardClick","e.stopPropagation","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx#formatDate","PAGE_SIZE_OPTIONS.map","setCurrentPage","setPageSize"],"usedImports":["useNavigate","useState","PageResult","GithubRepo","OverviewStatsDTO","LanguageStatsDTO","dayjs","useEffect","statsApi","starsApi","useCallback","useMemo","Spin","Row","Col","Card","Statistic","GithubOutlined","StarFilled","ForkOutlined","Tag","Space","Input","SearchOutlined","Select","Button","ClearOutlined","DownloadOutlined","Collapse","CaretDownOutlined","DatePicker","Avatar","Empty","Pagination"],"body":"{\n  const navigate = useNavigate()\n\n  // 服务端分页数据\n  const [pageResult, setPageResult] = useState<PageResult<GithubRepo>>({\n    records: [],\n    total: 0,\n    size: 12,\n    current: 1,\n    pages: 0,\n  })\n  const [overview, setOverview] = useState<OverviewStatsDTO | null>(null)\n  const [languageOptions, setLanguageOptions] = useState<LanguageStatsDTO[]>([])\n  const [loading, setLoading] = useState(true)\n  const [initialLoading, setInitialLoading] = useState(true)\n\n  // 筛选参数\n  const [keyword, setKeyword] = useState('')\n  const [selectedLanguages, setSelectedLanguages] = useState<string[]>([])\n  const [sortBy, setSortBy] = useState('starred_at')\n  const [sortOrder, setSortOrder] = useState('desc')\n  const [dateField, setDateField] = useState<string | undefined>(undefined)\n  const [startMonth, setStartMonth] = useState<dayjs.Dayjs | null>(null)\n  const [endMonth, setEndMonth] = useState<dayjs.Dayjs | null>(null)\n\n  const [currentPage, setCurrentPage] = useState(1)\n  const [pageSize, setPageSize] = useState(12)\n\n  // 首次加载：获取概览统计 + 语言列表\n  useEffect(() => {\n    const loadMeta = async () => {\n      try {\n        const [overviewRes, langRes] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n        ])\n        if (overviewRes.status === 'fulfilled') {\n          setOverview(overviewRes.value)\n        }\n        if (langRes.status === 'fulfilled') {\n          setLanguageOptions(langRes.value)\n        }\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setInitialLoading(false)\n      }\n    }\n    loadMeta()\n  }, [])\n\n  // 服务端分页查询：筛选/排序/分页参数变化时重新请求\n  useEffect(() => {\n    const loadPage = async () => {\n      setLoading(true)\n      try {\n        const result = await starsApi.fetchStarList({\n          page: currentPage,\n          size: pageSize,\n          keyword: keyword || undefined,\n          language: selectedLanguages.length > 0 ? selectedLanguages.join(',') : undefined,\n          sortBy: sortBy || undefined,\n          sortOrder: sortOrder || undefined,\n          dateField: dateField || undefined,\n          startMonth: startMonth ? startMonth.format('YYYY-MM') : undefined,\n          endMonth: endMonth ? endMonth.format('YYYY-MM') : undefined,\n        })\n        setPageResult(result)\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setLoading(false)\n      }\n    }\n    loadPage()\n  }, [currentPage, pageSize, keyword, selectedLanguages, sortBy, sortOrder, dateField, startMonth, endMonth])\n\n  const handleClearFilters = useCallback(() => {\n    setKeyword('')\n    setSelectedLanguages([])\n    setSortBy('starred_at')\n    setSortOrder('desc')\n    setDateField(undefined)\n    setStartMonth(null)\n    setEndMonth(null)\n    setCurrentPage(1)\n  }, [])\n\n  // 筛选条件变化时回到第一页\n  useEffect(() => {\n    setCurrentPage(1)\n  }, [pageSize])\n\n  const handleExport = useCallback(async () => {\n    try {\n      const blob = await starsApi.exportStarsUrls({\n        keyword: keyword || undefined,\n        language: selectedLanguages.length > 0 ? selectedLanguages.join(',') : undefined,\n        sortBy: sortBy || undefined,\n        sortOrder: sortOrder || undefined,\n        dateField: dateField || undefined,\n        startMonth: startMonth ? startMonth.format('YYYY-MM') : undefined,\n        endMonth: endMonth ? endMonth.format('YYYY-MM') : undefined,\n      })\n      const url = window.URL.createObjectURL(blob)\n      const a = document.createElement('a')\n      a.href = url\n      a.download = `stars_export_${dayjs().format('YYYYMMDD_HHmmss')}.txt`\n      document.body.appendChild(a)\n      a.click()\n      document.body.removeChild(a)\n      window.URL.revokeObjectURL(url)\n    } catch {\n      console.error('导出失败')\n    }\n  }, [keyword, selectedLanguages, sortBy, sortOrder, dateField, startMonth, endMonth])\n\n  const handleCardClick = useCallback(\n    (repo: GithubRepo) => {\n      navigate(`/stars/${repo.id}`, { state: { repo } })\n    },\n    [navigate],\n  )\n\n  const languageSelectOptions = useMemo(\n    () =>\n      languageOptions.map((lang) => ({\n        label: `${lang.language} (${lang.count})`,\n        value: lang.language,\n      })),\n    [languageOptions],\n  )\n\n  const hasActiveFilters =\n    keyword.trim() !== '' ||\n    selectedLanguages.length > 0 ||\n    sortBy !== 'starred_at' ||\n    sortOrder !== 'desc' ||\n    dateField !== undefined ||\n    startMonth !== null ||\n    endMonth !== null\n\n  const { records: repos } = pageResult\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        Star 仓库列表\n      </Title>\n\n      <Spin spinning={initialLoading}>\n        <Row gutter={[16, 16]} style={{ marginBottom: 20 }}>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"总仓库数\"\n                value={overview?.totalRepos ?? 0}\n                prefix={<GithubOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"总 Star 数\"\n                value={overview?.totalStars ?? 0}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"总 Fork 数\"\n                value={overview?.totalForks ?? 0}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={6}>\n            <Card size=\"small\">\n              <Statistic\n                title=\"语言种类\"\n                value={overview?.totalLanguages ?? 0}\n                prefix={<Tag color=\"purple\" style={{ marginRight: 0 }}>#</Tag>}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Spin>\n\n      <Card style={{ marginBottom: 20 }}>\n        <Space direction=\"vertical\" size=\"middle\" style={{ width: '100%' }}>\n          <Row gutter={[16, 16]} align=\"middle\">\n            <Col xs={24} sm={12} md={8} lg={6}>\n              <Input.Search\n                placeholder=\"搜索仓库名、描述、作者...\"\n                value={keyword}\n                onChange={(e) => setKeyword(e.target.value)}\n                onSearch={(val) => {\n                  setKeyword(val)\n                  setCurrentPage(1)\n                }}\n                allowClear\n                enterButton={<SearchOutlined />}\n              />\n            </Col>\n            <Col xs={24} sm={12} md={10} lg={7}>\n              <Select\n                mode=\"multiple\"\n                placeholder=\"筛选语言\"\n                value={selectedLanguages}\n                onChange={(vals) => {\n                  setSelectedLanguages(vals)\n                  setCurrentPage(1)\n                }}\n                options={languageSelectOptions}\n                allowClear\n                showSearch\n                maxTagCount={3}\n                filterOption={(input, option) =>\n                  (option?.label as string)?.toLowerCase().includes(input.toLowerCase())\n                }\n                style={{ width: '100%' }}\n              />\n            </Col>\n            <Col xs={12} sm={8} md={6} lg={4}>\n              <Select\n                placeholder=\"排序字段\"\n                value={sortBy}\n                onChange={(val) => {\n                  setSortBy(val)\n                  setCurrentPage(1)\n                }}\n                options={SORT_BY_OPTIONS}\n                style={{ width: '100%' }}\n              />\n            </Col>\n            <Col xs={12} sm={8} md={6} lg={3}>\n              <Select\n                placeholder=\"排序方向\"\n                value={sortOrder}\n                onChange={(val) => {\n                  setSortOrder(val)\n                  setCurrentPage(1)\n                }}\n                options={SORT_ORDER_OPTIONS}\n                style={{ width: '100%' }}\n              />\n            </Col>\n            <Col xs={24} sm={8} md={12} lg={4}>\n              <Space.Compact style={{ width: '100%' }}>\n                {hasActiveFilters && (\n                  <Button icon={<ClearOutlined />} onClick={handleClearFilters}>\n                    清除筛选\n                  </Button>\n                )}\n                <Button\n                  type=\"primary\"\n                  icon={<DownloadOutlined />}\n                  onClick={handleExport}\n                >\n                  导出链接\n                </Button>\n              </Space.Compact>\n            </Col>\n          </Row>\n\n          <Collapse\n            ghost\n            size=\"small\"\n            items={[\n              {\n                key: 'date-filter',\n                label: (\n                  <span style={{ fontSize: 13, color: '#666' }}>\n                    <CaretDownOutlined style={{ marginRight: 4 }} />\n                    时间筛选\n                  </span>\n                ),\n                children: (\n                  <Row gutter={[16, 12]} align=\"middle\">\n                    <Col xs={24} sm={8} md={6} lg={4}>\n                      <Select\n                        placeholder=\"时间字段\"\n                        value={dateField}\n                        onChange={(val) => {\n                          setDateField(val)\n                          setCurrentPage(1)\n                        }}\n                        allowClear\n                        options={DATE_FIELD_OPTIONS}\n                        style={{ width: '100%' }}\n                      />\n                    </Col>\n                    <Col xs={12} sm={8} md={6} lg={4}>\n                      <DatePicker\n                        picker=\"month\"\n                        placeholder=\"起始月份\"\n                        value={startMonth}\n                        onChange={(val) => {\n                          setStartMonth(val)\n                          setCurrentPage(1)\n                        }}\n                        disabled={!dateField}\n                        style={{ width: '100%' }}\n                      />\n                    </Col>\n                    <Col xs={12} sm={8} md={6} lg={4}>\n                      <DatePicker\n                        picker=\"month\"\n                        placeholder=\"结束月份\"\n                        value={endMonth}\n                        onChange={(val) => {\n                          setEndMonth(val)\n                          setCurrentPage(1)\n                        }}\n                        disabled={!dateField}\n                        style={{ width: '100%' }}\n                      />\n                    </Col>\n                  </Row>\n                ),\n              },\n            ]}\n          />\n        </Space>\n      </Card>\n\n      <Spin spinning={loading}>\n        {repos.length > 0 ? (\n          <Row gutter={[16, 16]}>\n            {repos.map((repo) => (\n              <Col key={repo.id} xs={24} sm={12} md={8} lg={6}>\n                <Card\n                  hoverable\n                  style={{ height: '100%', cursor: 'pointer' }}\n                  onClick={() => handleCardClick(repo)}\n                  styles={{ body: { padding: 16 } }}\n                >\n                  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, marginBottom: 10 }}>\n                    <Avatar\n                      src={repo.ownerAvatarUrl}\n                      alt={repo.ownerName}\n                      size={40}\n                      style={{ flexShrink: 0 }}\n                    />\n                    <div style={{ minWidth: 0, flex: 1 }}>\n                      <Text\n                        strong\n                        style={{ fontSize: 14, display: 'block', lineHeight: '20px' }}\n                        ellipsis\n                      >\n                        <a\n                          onClick={(e) => {\n                            e.stopPropagation()\n                            navigate(`/stars/${repo.id}`, { state: { repo } })\n                          }}\n                          style={{ color: '#1677ff' }}\n                        >\n                          {repo.repoName}\n                        </a>\n                      </Text>\n                      <Text type=\"secondary\" style={{ fontSize: 12 }} ellipsis>\n                        {repo.ownerName}\n                      </Text>\n                    </div>\n                  </div>\n                  {repo.description && (\n                    <Paragraph\n                      type=\"secondary\"\n                      ellipsis={{ rows: 2 }}\n                      style={{ marginBottom: 10, fontSize: 12, minHeight: 36 }}\n                    >\n                      {repo.description}\n                    </Paragraph>\n                  )}\n                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n                    {repo.language && (\n                      <Tag color=\"blue\" style={{ margin: 0 }}>\n                        {repo.language}\n                      </Tag>\n                    )}\n                    <Space size={4}>\n                      <StarFilled style={{ color: '#faad14', fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.starsCount}</Text>\n                    </Space>\n                    <Space size={4}>\n                      <ForkOutlined style={{ fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.forksCount}</Text>\n                    </Space>\n                  </div>\n                  <Text type=\"secondary\" style={{ fontSize: 11 }}>\n                    Star 于 {formatDate(repo.starredAt)}\n                  </Text>\n                </Card>\n              </Col>\n            ))}\n          </Row>\n        ) : (\n          <Card>\n            <Empty\n              description={\n                loading\n                  ? '加载中...'\n                  : pageResult.total === 0\n                    ? '暂无仓库数据，请先同步'\n                    : '筛选无结果，请尝试调整筛选条件'\n              }\n            >\n              {hasActiveFilters && (\n                <Button type=\"primary\" onClick={handleClearFilters}>\n                  清除所有筛选\n                </Button>\n              )}\n            </Empty>\n          </Card>\n        )}\n\n        {pageResult.total > pageSize && (\n          <div style={{ marginTop: 20, display: 'flex', justifyContent: 'center' }}>\n            <Pagination\n              current={currentPage}\n              pageSize={pageSize}\n              total={pageResult.total}\n              showSizeChanger\n              pageSizeOptions={PAGE_SIZE_OPTIONS.map(String)}\n              showQuickJumper\n              showTotal={(total) => `共 ${total} 条 / ${pageResult.pages} 页`}\n              onChange={(page, size) => {\n                setCurrentPage(page)\n                if (size !== pageSize) {\n                  setPageSize(size)\n                }\n              }}\n            />\n          </div>\n        )}\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useNavigate","line":73,"customHook":true},{"name":"useState","line":76,"customHook":false},{"name":"useState","line":83,"customHook":false},{"name":"useState","line":84,"customHook":false},{"name":"useState","line":85,"customHook":false},{"name":"useState","line":86,"customHook":false},{"name":"useState","line":89,"customHook":false},{"name":"useState","line":90,"customHook":false},{"name":"useState","line":91,"customHook":false},{"name":"useState","line":92,"customHook":false},{"name":"useState","line":93,"customHook":false},{"name":"useState","line":94,"customHook":false},{"name":"useState","line":95,"customHook":false},{"name":"useState","line":97,"customHook":false},{"name":"useState","line":98,"customHook":false},{"name":"useEffect","line":101,"customHook":false},{"name":"useEffect","line":124,"customHook":false},{"name":"useCallback","line":149,"customHook":false},{"name":"useEffect","line":161,"customHook":false},{"name":"useCallback","line":165,"customHook":false},{"name":"useCallback","line":189,"customHook":false},{"name":"useMemo","line":196,"customHook":false}],"jsxElements":["div","Title","Spin","Row","Col","Card","Statistic","GithubOutlined","StarFilled","ForkOutlined","Tag","Space","Input.Search","SearchOutlined","Select","Space.Compact","Button","ClearOutlined","DownloadOutlined","Collapse","span","CaretDownOutlined","DatePicker","Avatar","Text","a","Paragraph","Empty","Pagination"],"complexity":16,"calledBy":[]},"meta":{"revision":0,"created":1780675320126,"version":0},"$loki":58},{"name":"loadMeta","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":102,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function loadMeta","context":"Defined in StarList.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","setOverview","setLanguageOptions","setInitialLoading"],"usedImports":["statsApi"],"body":"{\n      try {\n        const [overviewRes, langRes] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n        ])\n        if (overviewRes.status === 'fulfilled') {\n          setOverview(overviewRes.value)\n        }\n        if (langRes.status === 'fulfilled') {\n          setLanguageOptions(langRes.value)\n        }\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setInitialLoading(false)\n      }\n    }","calledBy":[]},"meta":{"revision":0,"created":1780675320132,"version":0},"$loki":59},{"name":"loadPage","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":125,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function loadPage","context":"Defined in StarList.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","../api/stars#starsApi.fetchStarList","selectedLanguages.join","startMonth.format","endMonth.format","setPageResult","setLoading"],"usedImports":["starsApi"],"body":"{\n      setLoading(true)\n      try {\n        const result = await starsApi.fetchStarList({\n          page: currentPage,\n          size: pageSize,\n          keyword: keyword || undefined,\n          language: selectedLanguages.length > 0 ? selectedLanguages.join(',') : undefined,\n          sortBy: sortBy || undefined,\n          sortOrder: sortOrder || undefined,\n          dateField: dateField || undefined,\n          startMonth: startMonth ? startMonth.format('YYYY-MM') : undefined,\n          endMonth: endMonth ? endMonth.format('YYYY-MM') : undefined,\n        })\n        setPageResult(result)\n      } catch {\n        // errors already logged by interceptor\n      } finally {\n        setLoading(false)\n      }\n    }","calledBy":[]},"meta":{"revision":0,"created":1780675320133,"version":0},"$loki":60},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":404,"startLine":404,"endLine":469,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in StarList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Col","Card","div","Avatar","Text","a","Paragraph","Tag","Space","StarFilled","ForkOutlined"],"isExported":false,"complexity":1,"body":"(\n              <Col key={repo.id} xs={24} sm={12} md={8} lg={6}>\n                <Card\n                  hoverable\n                  style={{ height: '100%', cursor: 'pointer' }}\n                  onClick={() => handleCardClick(repo)}\n                  styles={{ body: { padding: 16 } }}\n                >\n                  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, marginBottom: 10 }}>\n                    <Avatar\n                      src={repo.ownerAvatarUrl}\n                      alt={repo.ownerName}\n                      size={40}\n                      style={{ flexShrink: 0 }}\n                    />\n                    <div style={{ minWidth: 0, flex: 1 }}>\n                      <Text\n                        strong\n                        style={{ fontSize: 14, display: 'block', lineHeight: '20px' }}\n                        ellipsis\n                      >\n                        <a\n                          onClick={(e) => {\n                            e.stopPropagation()\n                            navigate(`/stars/${repo.id}`, { state: { repo } })\n                          }}\n                          style={{ color: '#1677ff' }}\n                        >\n                          {repo.repoName}\n                        </a>\n                      </Text>\n                      <Text type=\"secondary\" style={{ fontSize: 12 }} ellipsis>\n                        {repo.ownerName}\n                      </Text>\n                    </div>\n                  </div>\n                  {repo.description && (\n                    <Paragraph\n                      type=\"secondary\"\n                      ellipsis={{ rows: 2 }}\n                      style={{ marginBottom: 10, fontSize: 12, minHeight: 36 }}\n                    >\n                      {repo.description}\n                    </Paragraph>\n                  )}\n                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n                    {repo.language && (\n                      <Tag color=\"blue\" style={{ margin: 0 }}>\n                        {repo.language}\n                      </Tag>\n                    )}\n                    <Space size={4}>\n                      <StarFilled style={{ color: '#faad14', fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.starsCount}</Text>\n                    </Space>\n                    <Space size={4}>\n                      <ForkOutlined style={{ fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.forksCount}</Text>\n                    </Space>\n                  </div>\n                  <Text type=\"secondary\" style={{ fontSize: 11 }}>\n                    Star 于 {formatDate(repo.starredAt)}\n                  </Text>\n                </Card>\n              </Col>\n            )","usedImports":["Col","Card","Avatar","Tag","Space","StarFilled","ForkOutlined"],"calledBy":[]},"meta":{"revision":0,"created":1780675320133,"version":0},"$loki":61}],"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx":[{"name":"formatNumber","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":52,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Function formatNumber implementation","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["toFixed","toFixed","String"],"usedImports":[],"body":"{\n  if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M'\n  if (n >= 1000) return (n / 1000).toFixed(1) + 'K'\n  return String(n)\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320137,"version":0},"$loki":62},{"name":"formatDate","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":58,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Function formatDate implementation","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["Array.isArray","padStart","String","padStart","String","dateStr.substring","String"],"usedImports":[],"body":"{\n  if (!dateStr) return '-'\n  if (Array.isArray(dateStr)) {\n    const [y, m, d] = dateStr\n    return `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`\n  }\n  if (typeof dateStr === 'string') {\n    return dateStr.length >= 10 ? dateStr.substring(0, 10) : dateStr\n  }\n  return String(dateStr)\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320138,"version":0},"$loki":63},{"name":"Stats","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":70,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useState","useState","useState","useState","useState","useState","useState","useEffect","setLoading","Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","../api/stats#statsApi.fetchOwnerStats","../api/stats#statsApi.fetchTimelineStats","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","setOverview","setLanguages","setOwners","setTimeline","setTopRepos","setRecentRepos","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#fetchAll","languages.slice","reduce","languages.slice","concat","langTop.map","concat","langTop.map","CHART_COLORS.slice","owners.map","owners.map","timeline.map","timeline.map","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatDate","da.localeCompare","topRepos.map","recentRepos.map","languages.reduce","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","toFixed"],"usedImports":["useState","OverviewStatsDTO","LanguageStatsDTO","OwnerStatsDTO","TimelineStatsDTO","GithubRepo","useEffect","statsApi","GithubOutlined","Tag","Spin","Row","Col","Card","Statistic","StarFilled","ForkOutlined","Doughnut","Bar","Line","Table"],"body":"{\n  const [overview, setOverview] = useState<OverviewStatsDTO | null>(null)\n  const [languages, setLanguages] = useState<LanguageStatsDTO[]>([])\n  const [owners, setOwners] = useState<OwnerStatsDTO[]>([])\n  const [timeline, setTimeline] = useState<TimelineStatsDTO[]>([])\n  const [topRepos, setTopRepos] = useState<GithubRepo[]>([])\n  const [recentRepos, setRecentRepos] = useState<GithubRepo[]>([])\n  const [loading, setLoading] = useState(true)\n\n  useEffect(() => {\n    const fetchAll = async () => {\n      setLoading(true)\n      try {\n        const [\n          overviewRes,\n          languagesRes,\n          ownersRes,\n          timelineRes,\n          topReposRes,\n          recentReposRes,\n        ] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n          statsApi.fetchOwnerStats(TOP_N_OWNERS),\n          statsApi.fetchTimelineStats(),\n          statsApi.fetchTopStarredRepos(TOP_N_REPOS),\n          statsApi.fetchRecentActiveRepos(TOP_N_REPOS),\n        ])\n\n        if (overviewRes.status === 'fulfilled') setOverview(overviewRes.value)\n        if (languagesRes.status === 'fulfilled') setLanguages(languagesRes.value)\n        if (ownersRes.status === 'fulfilled') setOwners(ownersRes.value)\n        if (timelineRes.status === 'fulfilled') setTimeline(timelineRes.value)\n        if (topReposRes.status === 'fulfilled') setTopRepos(topReposRes.value)\n        if (recentReposRes.status === 'fulfilled') setRecentRepos(recentReposRes.value)\n      } finally {\n        setLoading(false)\n      }\n    }\n    fetchAll()\n  }, [])\n\n  const langTop = languages.slice(0, TOP_N_LANGUAGES)\n  const langOthers = languages.slice(TOP_N_LANGUAGES).reduce((sum, l) => sum + l.count, 0)\n\n  const languageDoughnutData = {\n    labels: langTop.map((l) => l.language).concat(langOthers > 0 ? ['其他'] : []),\n    datasets: [\n      {\n        data: langTop.map((l) => l.count).concat(langOthers > 0 ? [langOthers] : []),\n        backgroundColor: CHART_COLORS.slice(0, langTop.length + (langOthers > 0 ? 1 : 0)),\n        borderWidth: 1,\n      },\n    ],\n  }\n\n  const ownerBarData = {\n    labels: owners.map((o) => o.ownerName),\n    datasets: [\n      {\n        label: '仓库数量',\n        data: owners.map((o) => o.count),\n        backgroundColor: '#36A2EB',\n        borderRadius: 4,\n      },\n    ],\n  }\n\n  const timelineLineData = {\n    labels: timeline.map((t) => t.month),\n    datasets: [\n      {\n        label: 'Star 数量',\n        data: timeline.map((t) => t.count),\n        fill: true,\n        tension: 0.3,\n        borderColor: '#FF6384',\n        backgroundColor: 'rgba(255, 99, 132, 0.15)',\n        pointRadius: 3,\n        pointHoverRadius: 6,\n      },\n    ],\n  }\n\n  const topStarredColumns = [\n    { title: '排名', dataIndex: 'rank', key: 'rank', width: 60, align: 'center' as const },\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 100,\n      render: (lang: string | null) => (lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>),\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n      sorter: (a: { starsCount: number }, b: { starsCount: number }) => a.starsCount - b.starsCount,\n    },\n    {\n      title: 'Fork数',\n      dataIndex: 'forksCount',\n      key: 'forksCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n    },\n  ]\n\n  const recentActiveColumns = [\n    { title: '排名', dataIndex: 'rank', key: 'rank', width: 60, align: 'center' as const },\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 100,\n      render: (lang: string | null) => (lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>),\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n    },\n    {\n      title: '最近更新时间',\n      dataIndex: 'repoUpdatedAt',\n      key: 'repoUpdatedAt',\n      width: 130,\n      render: (v: string | null) => formatDate(v),\n      sorter: (a: { repoUpdatedAt: string | null }, b: { repoUpdatedAt: string | null }) => {\n        const da = a.repoUpdatedAt ?? ''\n        const db = b.repoUpdatedAt ?? ''\n        return da.localeCompare(db)\n      },\n    },\n  ]\n\n  const topStarredSource = topRepos.map((r, i) => ({ ...r, key: r.id, rank: i + 1 }))\n  const recentActiveSource = recentRepos.map((r, i) => ({ ...r, key: r.id, rank: i + 1 }))\n\n  const totalLanguageCount = languages.reduce((sum, l) => sum + l.count, 0)\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        数据统计\n      </Title>\n\n      <Spin spinning={loading}>\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={12} sm={8} md={4}>\n            <Card>\n              <Statistic\n                title=\"总仓库数\"\n                value={overview?.totalRepos ?? 0}\n                prefix={<GithubOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"总 Star 数\"\n                value={overview?.totalStars ?? 0}\n                formatter={(value) => formatNumber(value as number)}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"总 Fork 数\"\n                value={overview?.totalForks ?? 0}\n                formatter={(value) => formatNumber(value as number)}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"语言种类数\"\n                value={overview?.totalLanguages ?? 0}\n                prefix={<Tag color=\"purple\" style={{ marginRight: 0 }}>#</Tag>}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"作者数\"\n                value={overview?.totalOwners ?? 0}\n                prefix={<StarFilled style={{ color: '#eb2f96' }} />}\n              />\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={24} lg={12}>\n            <Card title=\"语言分布\" style={{ height: '100%' }}>\n              {languages.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Doughnut\n                    data={languageDoughnutData}\n                    options={{\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      plugins: {\n                        legend: {\n                          position: 'right' as const,\n                          labels: { boxWidth: 12, padding: 8, font: { size: 11 } },\n                        },\n                        tooltip: {\n                          callbacks: {\n                            label: (ctx: { label: string; parsed: number }) => {\n                              const pct = totalLanguageCount > 0\n                                ? ((ctx.parsed / totalLanguageCount) * 100).toFixed(1)\n                                : '0'\n                              return `${ctx.label}: ${ctx.parsed} (${pct}%)`\n                            },\n                          },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无语言数据\n                </div>\n              )}\n            </Card>\n          </Col>\n          <Col xs={24} lg={12}>\n            <Card title=\"作者排行\" style={{ height: '100%' }}>\n              {owners.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Bar\n                    data={ownerBarData}\n                    options={{\n                      indexAxis: 'y' as const,\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      plugins: {\n                        legend: { display: false },\n                      },\n                      scales: {\n                        x: {\n                          title: { display: true, text: '仓库数量' },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无作者数据\n                </div>\n              )}\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col span={24}>\n            <Card title=\"Star 时间趋势\">\n              {timeline.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Line\n                    data={timelineLineData}\n                    options={{\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      interaction: {\n                        intersect: false,\n                        mode: 'index' as const,\n                      },\n                      plugins: {\n                        legend: {\n                          position: 'top' as const,\n                        },\n                      },\n                      scales: {\n                        y: {\n                          title: { display: true, text: 'Star 数量' },\n                          beginAtZero: true,\n                        },\n                        x: {\n                          title: { display: true, text: '月份' },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无时间线数据\n                </div>\n              )}\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]}>\n          <Col xs={24} lg={12}>\n            <Card title=\"最受欢迎仓库 Top 10\">\n              <Table\n                columns={topStarredColumns}\n                dataSource={topStarredSource}\n                pagination={false}\n                size=\"small\"\n                scroll={{ x: 500 }}\n              />\n            </Card>\n          </Col>\n          <Col xs={24} lg={12}>\n            <Card title=\"最近活跃仓库 Top 10\">\n              <Table\n                columns={recentActiveColumns}\n                dataSource={recentActiveSource}\n                pagination={false}\n                size=\"small\"\n                scroll={{ x: 520 }}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":71,"customHook":false},{"name":"useState","line":72,"customHook":false},{"name":"useState","line":73,"customHook":false},{"name":"useState","line":74,"customHook":false},{"name":"useState","line":75,"customHook":false},{"name":"useState","line":76,"customHook":false},{"name":"useState","line":77,"customHook":false},{"name":"useEffect","line":79,"customHook":false}],"jsxElements":["a","GithubOutlined","Tag","div","Title","Spin","Row","Col","Card","Statistic","StarFilled","ForkOutlined","Doughnut","Bar","Line","Table"],"comp