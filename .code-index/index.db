        // errors already logged by interceptor\n      } finally {\n        setLoading(false)\n      }\n    }","calledBy":[]},"meta":{"revision":0,"created":1780675320133,"version":0},"$loki":60},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\StarList.tsx","lineNumber":404,"startLine":404,"endLine":469,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in StarList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["Col","Card","div","Avatar","Text","a","Paragraph","Tag","Space","StarFilled","ForkOutlined"],"isExported":false,"complexity":1,"body":"(\n              <Col key={repo.id} xs={24} sm={12} md={8} lg={6}>\n                <Card\n                  hoverable\n                  style={{ height: '100%', cursor: 'pointer' }}\n                  onClick={() => handleCardClick(repo)}\n                  styles={{ body: { padding: 16 } }}\n                >\n                  <div style={{ display: 'flex', alignItems: 'flex-start', gap: 10, marginBottom: 10 }}>\n                    <Avatar\n                      src={repo.ownerAvatarUrl}\n                      alt={repo.ownerName}\n                      size={40}\n                      style={{ flexShrink: 0 }}\n                    />\n                    <div style={{ minWidth: 0, flex: 1 }}>\n                      <Text\n                        strong\n                        style={{ fontSize: 14, display: 'block', lineHeight: '20px' }}\n                        ellipsis\n                      >\n                        <a\n                          onClick={(e) => {\n                            e.stopPropagation()\n                            navigate(`/stars/${repo.id}`, { state: { repo } })\n                          }}\n                          style={{ color: '#1677ff' }}\n                        >\n                          {repo.repoName}\n                        </a>\n                      </Text>\n                      <Text type=\"secondary\" style={{ fontSize: 12 }} ellipsis>\n                        {repo.ownerName}\n                      </Text>\n                    </div>\n                  </div>\n                  {repo.description && (\n                    <Paragraph\n                      type=\"secondary\"\n                      ellipsis={{ rows: 2 }}\n                      style={{ marginBottom: 10, fontSize: 12, minHeight: 36 }}\n                    >\n                      {repo.description}\n                    </Paragraph>\n                  )}\n                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>\n                    {repo.language && (\n                      <Tag color=\"blue\" style={{ margin: 0 }}>\n                        {repo.language}\n                      </Tag>\n                    )}\n                    <Space size={4}>\n                      <StarFilled style={{ color: '#faad14', fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.starsCount}</Text>\n                    </Space>\n                    <Space size={4}>\n                      <ForkOutlined style={{ fontSize: 12 }} />\n                      <Text style={{ fontSize: 12 }}>{repo.forksCount}</Text>\n                    </Space>\n                  </div>\n                  <Text type=\"secondary\" style={{ fontSize: 11 }}>\n                    Star 于 {formatDate(repo.starredAt)}\n                  </Text>\n                </Card>\n              </Col>\n            )","usedImports":["Col","Card","Avatar","Tag","Space","StarFilled","ForkOutlined"],"calledBy":[]},"meta":{"revision":0,"created":1780675320133,"version":0},"$loki":61},{"name":"formatNumber","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":52,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Function formatNumber implementation","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["toFixed","toFixed","String"],"usedImports":[],"body":"{\n  if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M'\n  if (n >= 1000) return (n / 1000).toFixed(1) + 'K'\n  return String(n)\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320137,"version":0},"$loki":62},{"name":"formatDate","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":58,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"Function formatDate implementation","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["Array.isArray","padStart","String","padStart","String","dateStr.substring","String"],"usedImports":[],"body":"{\n  if (!dateStr) return '-'\n  if (Array.isArray(dateStr)) {\n    const [y, m, d] = dateStr\n    return `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`\n  }\n  if (typeof dateStr === 'string') {\n    return dateStr.length >= 10 ? dateStr.substring(0, 10) : dateStr\n  }\n  return String(dateStr)\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320138,"version":0},"$loki":63},{"name":"Stats","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx","lineNumber":70,"language":"typescript","dependencies":["react","antd","@ant-design/icons","react-chartjs-2","chart.js"],"purpose":"React functional component","context":"Located in Stats.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useState","useState","useState","useState","useState","useState","useState","useEffect","setLoading","Promise.allSettled","../api/stats#statsApi.fetchOverviewStats","../api/stats#statsApi.fetchLanguageStats","../api/stats#statsApi.fetchOwnerStats","../api/stats#statsApi.fetchTimelineStats","../api/stats#statsApi.fetchTopStarredRepos","../api/stats#statsApi.fetchRecentActiveRepos","setOverview","setLanguages","setOwners","setTimeline","setTopRepos","setRecentRepos","setLoading","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#fetchAll","languages.slice","reduce","languages.slice","concat","langTop.map","concat","langTop.map","CHART_COLORS.slice","owners.map","owners.map","timeline.map","timeline.map","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatDate","da.localeCompare","topRepos.map","recentRepos.map","languages.reduce","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Stats.tsx#formatNumber","toFixed"],"usedImports":["useState","OverviewStatsDTO","LanguageStatsDTO","OwnerStatsDTO","TimelineStatsDTO","GithubRepo","useEffect","statsApi","GithubOutlined","Tag","Spin","Row","Col","Card","Statistic","StarFilled","ForkOutlined","Doughnut","Bar","Line","Table"],"body":"{\n  const [overview, setOverview] = useState<OverviewStatsDTO | null>(null)\n  const [languages, setLanguages] = useState<LanguageStatsDTO[]>([])\n  const [owners, setOwners] = useState<OwnerStatsDTO[]>([])\n  const [timeline, setTimeline] = useState<TimelineStatsDTO[]>([])\n  const [topRepos, setTopRepos] = useState<GithubRepo[]>([])\n  const [recentRepos, setRecentRepos] = useState<GithubRepo[]>([])\n  const [loading, setLoading] = useState(true)\n\n  useEffect(() => {\n    const fetchAll = async () => {\n      setLoading(true)\n      try {\n        const [\n          overviewRes,\n          languagesRes,\n          ownersRes,\n          timelineRes,\n          topReposRes,\n          recentReposRes,\n        ] = await Promise.allSettled([\n          statsApi.fetchOverviewStats(),\n          statsApi.fetchLanguageStats(),\n          statsApi.fetchOwnerStats(TOP_N_OWNERS),\n          statsApi.fetchTimelineStats(),\n          statsApi.fetchTopStarredRepos(TOP_N_REPOS),\n          statsApi.fetchRecentActiveRepos(TOP_N_REPOS),\n        ])\n\n        if (overviewRes.status === 'fulfilled') setOverview(overviewRes.value)\n        if (languagesRes.status === 'fulfilled') setLanguages(languagesRes.value)\n        if (ownersRes.status === 'fulfilled') setOwners(ownersRes.value)\n        if (timelineRes.status === 'fulfilled') setTimeline(timelineRes.value)\n        if (topReposRes.status === 'fulfilled') setTopRepos(topReposRes.value)\n        if (recentReposRes.status === 'fulfilled') setRecentRepos(recentReposRes.value)\n      } finally {\n        setLoading(false)\n      }\n    }\n    fetchAll()\n  }, [])\n\n  const langTop = languages.slice(0, TOP_N_LANGUAGES)\n  const langOthers = languages.slice(TOP_N_LANGUAGES).reduce((sum, l) => sum + l.count, 0)\n\n  const languageDoughnutData = {\n    labels: langTop.map((l) => l.language).concat(langOthers > 0 ? ['其他'] : []),\n    datasets: [\n      {\n        data: langTop.map((l) => l.count).concat(langOthers > 0 ? [langOthers] : []),\n        backgroundColor: CHART_COLORS.slice(0, langTop.length + (langOthers > 0 ? 1 : 0)),\n        borderWidth: 1,\n      },\n    ],\n  }\n\n  const ownerBarData = {\n    labels: owners.map((o) => o.ownerName),\n    datasets: [\n      {\n        label: '仓库数量',\n        data: owners.map((o) => o.count),\n        backgroundColor: '#36A2EB',\n        borderRadius: 4,\n      },\n    ],\n  }\n\n  const timelineLineData = {\n    labels: timeline.map((t) => t.month),\n    datasets: [\n      {\n        label: 'Star 数量',\n        data: timeline.map((t) => t.count),\n        fill: true,\n        tension: 0.3,\n        borderColor: '#FF6384',\n        backgroundColor: 'rgba(255, 99, 132, 0.15)',\n        pointRadius: 3,\n        pointHoverRadius: 6,\n      },\n    ],\n  }\n\n  const topStarredColumns = [\n    { title: '排名', dataIndex: 'rank', key: 'rank', width: 60, align: 'center' as const },\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 100,\n      render: (lang: string | null) => (lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>),\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n      sorter: (a: { starsCount: number }, b: { starsCount: number }) => a.starsCount - b.starsCount,\n    },\n    {\n      title: 'Fork数',\n      dataIndex: 'forksCount',\n      key: 'forksCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n    },\n  ]\n\n  const recentActiveColumns = [\n    { title: '排名', dataIndex: 'rank', key: 'rank', width: 60, align: 'center' as const },\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 4 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 100,\n      render: (lang: string | null) => (lang ? <Tag>{lang}</Tag> : <Tag color=\"default\">-</Tag>),\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => formatNumber(v),\n    },\n    {\n      title: '最近更新时间',\n      dataIndex: 'repoUpdatedAt',\n      key: 'repoUpdatedAt',\n      width: 130,\n      render: (v: string | null) => formatDate(v),\n      sorter: (a: { repoUpdatedAt: string | null }, b: { repoUpdatedAt: string | null }) => {\n        const da = a.repoUpdatedAt ?? ''\n        const db = b.repoUpdatedAt ?? ''\n        return da.localeCompare(db)\n      },\n    },\n  ]\n\n  const topStarredSource = topRepos.map((r, i) => ({ ...r, key: r.id, rank: i + 1 }))\n  const recentActiveSource = recentRepos.map((r, i) => ({ ...r, key: r.id, rank: i + 1 }))\n\n  const totalLanguageCount = languages.reduce((sum, l) => sum + l.count, 0)\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        数据统计\n      </Title>\n\n      <Spin spinning={loading}>\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={12} sm={8} md={4}>\n            <Card>\n              <Statistic\n                title=\"总仓库数\"\n                value={overview?.totalRepos ?? 0}\n                prefix={<GithubOutlined style={{ color: '#1677ff' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"总 Star 数\"\n                value={overview?.totalStars ?? 0}\n                formatter={(value) => formatNumber(value as number)}\n                prefix={<StarFilled style={{ color: '#faad14' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"总 Fork 数\"\n                value={overview?.totalForks ?? 0}\n                formatter={(value) => formatNumber(value as number)}\n                prefix={<ForkOutlined style={{ color: '#52c41a' }} />}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"语言种类数\"\n                value={overview?.totalLanguages ?? 0}\n                prefix={<Tag color=\"purple\" style={{ marginRight: 0 }}>#</Tag>}\n              />\n            </Card>\n          </Col>\n          <Col xs={12} sm={8} md={5}>\n            <Card>\n              <Statistic\n                title=\"作者数\"\n                value={overview?.totalOwners ?? 0}\n                prefix={<StarFilled style={{ color: '#eb2f96' }} />}\n              />\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col xs={24} lg={12}>\n            <Card title=\"语言分布\" style={{ height: '100%' }}>\n              {languages.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Doughnut\n                    data={languageDoughnutData}\n                    options={{\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      plugins: {\n                        legend: {\n                          position: 'right' as const,\n                          labels: { boxWidth: 12, padding: 8, font: { size: 11 } },\n                        },\n                        tooltip: {\n                          callbacks: {\n                            label: (ctx: { label: string; parsed: number }) => {\n                              const pct = totalLanguageCount > 0\n                                ? ((ctx.parsed / totalLanguageCount) * 100).toFixed(1)\n                                : '0'\n                              return `${ctx.label}: ${ctx.parsed} (${pct}%)`\n                            },\n                          },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无语言数据\n                </div>\n              )}\n            </Card>\n          </Col>\n          <Col xs={24} lg={12}>\n            <Card title=\"作者排行\" style={{ height: '100%' }}>\n              {owners.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Bar\n                    data={ownerBarData}\n                    options={{\n                      indexAxis: 'y' as const,\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      plugins: {\n                        legend: { display: false },\n                      },\n                      scales: {\n                        x: {\n                          title: { display: true, text: '仓库数量' },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无作者数据\n                </div>\n              )}\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]} style={{ marginBottom: 24 }}>\n          <Col span={24}>\n            <Card title=\"Star 时间趋势\">\n              {timeline.length > 0 ? (\n                <div style={{ height: 400 }}>\n                  <Line\n                    data={timelineLineData}\n                    options={{\n                      responsive: true,\n                      maintainAspectRatio: false,\n                      interaction: {\n                        intersect: false,\n                        mode: 'index' as const,\n                      },\n                      plugins: {\n                        legend: {\n                          position: 'top' as const,\n                        },\n                      },\n                      scales: {\n                        y: {\n                          title: { display: true, text: 'Star 数量' },\n                          beginAtZero: true,\n                        },\n                        x: {\n                          title: { display: true, text: '月份' },\n                        },\n                      },\n                    }}\n                  />\n                </div>\n              ) : (\n                <div style={{ height: 400, display: 'flex', alignItems: 'center', justifyContent: 'center', color: '#999' }}>\n                  暂无时间线数据\n                </div>\n              )}\n            </Card>\n          </Col>\n        </Row>\n\n        <Row gutter={[16, 16]}>\n          <Col xs={24} lg={12}>\n            <Card title=\"最受欢迎仓库 Top 10\">\n              <Table\n                columns={topStarredColumns}\n                dataSource={topStarredSource}\n                pagination={false}\n                size=\"small\"\n                scroll={{ x: 500 }}\n              />\n            </Card>\n          </Col>\n          <Col xs={24} lg={12}>\n            <Card title=\"最近活跃仓库 Top 10\">\n              <Table\n                columns={recentActiveColumns}\n                dataSource={recentActiveSource}\n                pagination={false}\n                size=\"small\"\n                scroll={{ x: 520 }}\n              />\n            </Card>\n          </Col>\n        </Row>\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":71,"customHook":false},{"name":"useState","line":72,"customHook":false},{"name":"useState","line":73,"customHook":false},{"name":"useState","line":74,"customHook":false},{"name":"useState","line":75,"customHook":false},{"name":"useState","line":76,"cus