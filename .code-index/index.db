   background: token.colorBgContainer,\n          borderBottom: `1px solid ${token.colorBorderSecondary}`,\n          paddingInline: 24,\n          height: 56,\n          position: 'sticky',\n          top: 0,\n          zIndex: 100,\n        }}\n      >\n        <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>\n          <Text strong style={{ fontSize: 18, color: token.colorPrimary }}>\n            GitHub Stars\n          </Text>\n        </div>\n        <Menu\n          mode=\"horizontal\"\n          selectedKeys={[selectedKey]}\n          items={navItems}\n          onClick={({ key }) => navigate(key)}\n          style={{ flex: 1, justifyContent: 'flex-end', border: 'none', minWidth: 0 }}\n        />\n      </Header>\n      <Content style={{ padding: '16px 24px', maxWidth: 1400, width: '100%', margin: '0 auto' }}>\n        <Outlet />\n      </Content>\n      <Footer style={{ textAlign: 'center', color: token.colorTextTertiary, fontSize: 12 }}>\n        GitHub Stars 管理系统 ©{new Date().getFullYear()}\n      </Footer>\n    </Layout>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useNavigate","line":25,"customHook":true},{"name":"useLocation","line":26,"customHook":true}],"jsxElements":["Layout","Header","div","Text","Menu","Content","Outlet","Footer"],"complexity":2}},{"name":"formatDateTime","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":11,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Function formatDateTime implementation","context":"Located in CategoryDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["format","dayjs"],"usedImports":["dayjs"],"body":"{\n  if (!value) return '-'\n  return dayjs(value).format('YYYY-MM-DD HH:mm:ss')\n}"}},{"name":"CategoryDetail","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":16,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useParams","antd#App.useApp","useNavigate","useState","useState","useState","useState","setLoading","../api/categories#categoriesApi.fetchAllCategories","setAllCategories","data.find","Number","setCategory","message.error","setLoading","useEffect","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#fetchData","modal.confirm","setReclassifying","../api/categories#categoriesApi.reclassifyCategory","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#fetchData","message.error","message.error","setReclassifying","navigate","navigate","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#formatDateTime","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#formatDateTime","navigate"],"usedImports":["useParams","App","useNavigate","useState","Category","categoriesApi","useEffect","Spin","Breadcrumb","Empty","Button","ArrowLeftOutlined","Card","FolderOutlined","Descriptions","ThunderboltOutlined"],"body":"{\n  const { id } = useParams<{ id: string }>()\n  const { message, modal } = App.useApp()\n  const navigate = useNavigate()\n\n  const [category, setCategory] = useState<Category | null>(null)\n  const [allCategories, setAllCategories] = useState<Category[]>([])\n  const [reclassifying, setReclassifying] = useState(false)\n  const [loading, setLoading] = useState(false)\n\n  const fetchData = async () => {\n    setLoading(true)\n    try {\n      const data = await categoriesApi.fetchAllCategories()\n      setAllCategories(data)\n      const current = data.find((c) => c.id === Number(id))\n      if (current) {\n        setCategory(current)\n      }\n    } catch {\n      message.error('获取分类信息失败')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    if (id) {\n      fetchData()\n    }\n  }, [id])\n\n  const handleReclassify = () => {\n    if (!category) return\n    modal.confirm({\n      title: 'AI 重分类',\n      content: `将对分类「${category.name}」下的仓库使用 AI 重新进行分类，可能需要一些时间。是否继续？`,\n      okText: '开始重分类',\n      cancelText: '取消',\n      onOk: async () => {\n        setReclassifying(true)\n        try {\n          const res = await categoriesApi.reclassifyCategory(category.id, 8)\n          if (res.success) {\n            message.success('AI 重分类任务已触发，请稍后刷新查看结果')\n            fetchData()\n          } else {\n            message.error(res.message || 'AI 重分类失败')\n          }\n        } catch {\n          message.error('AI 重分类请求失败，请稍后重试')\n        } finally {\n          setReclassifying(false)\n        }\n      },\n    })\n  }\n\n  if (loading && !category) {\n    return (\n      <div style={{ textAlign: 'center', paddingTop: 100 }}>\n        <Spin size=\"large\" />\n      </div>\n    )\n  }\n\n  if (!loading && !category) {\n    return (\n      <div>\n        <Breadcrumb\n          items={[\n            { title: <a onClick={() => navigate('/categories')}>分类管理</a> },\n            { title: '未找到' },\n          ]}\n          style={{ marginBottom: 24 }}\n        />\n        <Empty description=\"分类不存在或已被删除\" />\n        <div style={{ textAlign: 'center', marginTop: 16 }}>\n          <Button icon={<ArrowLeftOutlined />} onClick={() => navigate('/categories')}>\n            返回分类列表\n          </Button>\n        </div>\n      </div>\n    )\n  }\n\n  return (\n    <div>\n      <Breadcrumb\n        items={[\n          { title: <a onClick={() => navigate('/categories')}>分类管理</a> },\n          { title: category?.name },\n        ]}\n        style={{ marginBottom: 24 }}\n      />\n\n      <Spin spinning={loading}>\n        <Card style={{ marginBottom: 24 }}>\n          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>\n            <div>\n              <Title level={4} style={{ marginBottom: 4 }}>\n                <FolderOutlined style={{ marginRight: 8 }} />\n                {category?.name}\n              </Title>\n              {category?.description && (\n                <Paragraph type=\"secondary\" style={{ marginBottom: 12, maxWidth: 600 }}>\n                  {category.description}\n                </Paragraph>\n              )}\n              <Descriptions size=\"small\" column={3}>\n                <Descriptions.Item label=\"仓库数量\">{category?.repoCount ?? 0}</Descriptions.Item>\n                <Descriptions.Item label=\"排序\">{category?.sortOrder ?? 0}</Descriptions.Item>\n                <Descriptions.Item label=\"创建时间\">\n                  {formatDateTime(category?.createdAt ?? null)}\n                </Descriptions.Item>\n                <Descriptions.Item label=\"更新时间\">\n                  {formatDateTime(category?.updatedAt ?? null)}\n                </Descriptions.Item>\n              </Descriptions>\n            </div>\n            <Button\n              type=\"primary\"\n              icon={<ThunderboltOutlined />}\n              onClick={handleReclassify}\n              loading={reclassifying}\n            >\n              AI 重分类\n            </Button>\n          </div>\n        </Card>\n\n        <Card title=\"仓库列表\">\n          <Empty description=\"仓库列表功能需要后端提供分类下仓库查询的 JSON API，敬请期待\" />\n        </Card>\n\n        <div style={{ marginTop: 16, textAlign: 'center' }}>\n          <Button icon={<ArrowLeftOutlined />} onClick={() => navigate('/categories')}>\n            返回分类列表\n          </Button>\n        </div>\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useParams","line":17,"customHook":true},{"name":"useNavigate","line":19,"customHook":true},{"name":"useState","line":21,"customHook":false},{"name":"useState","line":22,"customHook":false},{"name":"useState","line":23,"customHook":false},{"name":"useState","line":24,"customHook":false},{"name":"useEffect","line":42,"customHook":false}],"jsxElements":["div","Spin","Breadcrumb","a","Empty","Button","ArrowLeftOutlined","Card","Title","FolderOutlined","Paragraph","Descriptions","Descriptions.Item","ThunderboltOutlined"],"complexity":7}},{"name":"fetchData","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":26,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function fetchData","context":"Defined in CategoryDetail.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","../api/categories#categoriesApi.fetchAllCategories","setAllCategories","data.find","Number","setCategory","message.error","setLoading"],"usedImports":["categoriesApi"],"body":"{\n    setLoading(true)\n    try {\n      const data = await categoriesApi.fetchAllCategories()\n      setAllCategories(data)\n      const current = data.find((c) => c.id === Number(id))\n      if (current) {\n        setCategory(current)\n      }\n    } catch {\n      message.error('获取分类信息失败')\n    } finally {\n      setLoading(false)\n    }\n  }"}},{"name":"handleReclassify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":48,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleReclassify","context":"Defined in CategoryDetail.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["modal.confirm","setReclassifying","../api/categories#categoriesApi.reclassifyCategory","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#fetchData","message.error","message.error","setReclassifying"],"usedImports":["categoriesApi"],"body":"{\n    if (!category) return\n    modal.confirm({\n      title: 'AI 重分类',\n      content: `将对分类「${category.name}」下的仓库使用 AI 重新进行分类，可能需要一些时间。是否继续？`,\n      okText: '开始重分类',\n      cancelText: '取消',\n      onOk: async () => {\n        setReclassifying(true)\n        try {\n          const res = await categoriesApi.reclassifyCategory(category.id, 8)\n          if (res.success) {\n            message.success('AI 重分类任务已触发，请稍后刷新查看结果')\n            fetchData()\n          } else {\n            message.error(res.message || 'AI 重分类失败')\n          }\n        } catch {\n          message.error('AI 重分类请求失败，请稍后重试')\n        } finally {\n          setReclassifying(false)\n        }\n      },\n    })\n  }"}},{"name":"formatDateTime","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":12,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Function formatDateTime implementation","context":"Located in CategoryList.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["format","dayjs"],"usedImports":["dayjs"],"body":"{\n  if (!value) return '-'\n  return dayjs(value).format('YYYY-MM-DD HH:mm:ss')\n}"}},{"name":"CategoryList","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":17,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["antd#App.useApp","useNavigate","useState","useState","useState","useState","useState","useState","useState","useState","setLoading","../api/categories#categoriesApi.fetchAllCategories","setCategories","message.error","setLoading","use