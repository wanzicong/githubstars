pi"],"body":"{\n  const { data } = await api.post<ApiResponse>(`/categories/${categoryId}/repos`, { repoIds })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320044,"version":0},"$loki":8},{"name":"removeRepoFromCategory","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\categories.ts","lineNumber":39,"language":"typescript","dependencies":[],"purpose":"Function removeRepoFromCategory implementation","context":"Located in categories.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.delete"],"usedImports":["ApiResponse","api"],"body":"{\n  const { data } = await api.delete<ApiResponse>(`/categories/${categoryId}/repos/${repoId}`)\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320045,"version":0},"$loki":9},{"name":"transferRepos","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\categories.ts","lineNumber":44,"language":"typescript","dependencies":[],"purpose":"Function transferRepos implementation","context":"Located in categories.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":3,"functionCalls":["./request#api.post"],"usedImports":["ApiResponse","api"],"body":"{\n  const { data } = await api.post<ApiResponse>(`/categories/${fromCategoryId}/repos/transfer`, {\n    repoIds,\n    toCategoryId,\n  })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320046,"version":0},"$loki":10},{"name":"reclassifyCategory","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\categories.ts","lineNumber":56,"language":"typescript","dependencies":[],"purpose":"Function reclassifyCategory implementation","context":"Located in categories.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.post"],"usedImports":["ApiResponse","api"],"body":"{\n  const { data } = await api.post<ApiResponse>(`/categories/${categoryId}/reclassify`, { topN })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320047,"version":0},"$loki":11},{"name":"fetchClassifyRepos","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\classify.ts","lineNumber":4,"language":"typescript","dependencies":[],"purpose":"Function fetchClassifyRepos implementation","context":"Located in classify.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.get"],"usedImports":["GithubRepo","api"],"body":"{\n  const { data } = await api.get<GithubRepo[]>('/ai/classify/repos', {\n    params: { keyword, language },\n  })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320049,"version":0},"$loki":12},{"name":"executeClassify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\classify.ts","lineNumber":11,"language":"typescript","dependencies":[],"purpose":"Function executeClassify implementation","context":"Located in classify.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.post"],"usedImports":["GithubRepo","api"],"body":"{\n  const { data } = await api.post('/ai/classify/execute', { repoIds, topN })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320050,"version":0},"$loki":13},{"name":"fetchStarList","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stars.ts","lineNumber":4,"language":"typescript","dependencies":[],"purpose":"Function fetchStarList implementation","context":"Located in stars.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":1,"functionCalls":["searchParams.set","String","searchParams.set","String","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","./request#api.get"],"usedImports":["StarListParams","PageResult","GithubRepo","api"],"body":"{\n  const searchParams = new URLSearchParams()\n  if (params.page) searchParams.set('page', String(params.page))\n  if (params.size) searchParams.set('size', String(params.size))\n  if (params.keyword) searchParams.set('keyword', params.keyword)\n  if (params.language) searchParams.set('language', params.language)\n  if (params.sortBy) searchParams.set('sortBy', params.sortBy)\n  if (params.sortOrder) searchParams.set('sortOrder', params.sortOrder)\n  if (params.dateField) searchParams.set('dateField', params.dateField)\n  if (params.startMonth) searchParams.set('startMonth', params.startMonth)\n  if (params.endMonth) searchParams.set('endMonth', params.endMonth)\n  const { data } = await api.get<PageResult<GithubRepo>>('/api/stars', { params: searchParams })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320051,"version":0},"$loki":14},{"name":"fetchStarDetail","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stars.ts","lineNumber":19,"language":"typescript","dependencies":[],"purpose":"Function fetchStarDetail implementation","context":"Located in stars.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.get"],"usedImports":["api"],"body":"{\n  const params = backQuery ? { backQuery } : {}\n  const { data } = await api.get<string>(`/stars/${id}`, { params })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320052,"version":0},"$loki":15},{"name":"exportStarsUrls","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stars.ts","lineNumber":25,"language":"typescript","dependencies":[],"purpose":"Function exportStarsUrls implementation","context":"Located in stars.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":1,"functionCalls":["searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","searchParams.set","./request#api.get"],"usedImports":["StarListParams","api"],"body":"{\n  const searchParams = new URLSearchParams()\n  if (params.keyword) searchParams.set('keyword', params.keyword)\n  if (params.language) searchParams.set('language', params.language)\n  if (params.sortBy) searchParams.set('sortBy', params.sortBy)\n  if (params.sortOrder) searchParams.set('sortOrder', params.sortOrder)\n  if (params.dateField) searchParams.set('dateField', params.dateField)\n  if (params.startMonth) searchParams.set('startMonth', params.startMonth)\n  if (params.endMonth) searchParams.set('endMonth', params.endMonth)\n  const { data } = await api.get('/stars/export', {\n    params: searchParams,\n    responseType: 'blob',\n  })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320053,"version":0},"$loki":16},{"name":"fetchLanguageStats","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stats.ts","lineNumber":10,"language":"typescript","dependencies":[],"purpose":"Function fetchLanguageStats implementation","context":"Located in stats.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":0,"functionCalls":["./request#api.get"],"usedImports":["LanguageStatsDTO","api"],"body":"{\n  const { data } = await api.get<LanguageStatsDTO[]>('/api/stats/languages')\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320055,"version":0},"$loki":17},{"name":"fetchOwnerStats","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\stats.ts","lineNumber":15,"language":"typescript","dependencies":[],"purpose":"Function fetchOwnerStats implementation","context":"Located in stats.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":1,"functionCalls":["./request#api.get"],"usedImports":["OwnerStatsDTO","api"],"body":"{\n  const { data } = await api.get<OwnerStatsDTO[]>('/api/stats/owners', { params: { topN } })\n  return data\n}","calledBy":[]