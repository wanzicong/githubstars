,"usedImports":["api"],"body":"{\n  const { data } = await api.post('/sync/manual')\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320062,"version":0},"$loki":23},{"name":"fetchSyncStatus","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\sync.ts","lineNumber":9,"language":"typescript","dependencies":[],"purpose":"Function fetchSyncStatus implementation","context":"Located in sync.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":0,"functionCalls":["./request#api.get"],"usedImports":["SyncStatus","api"],"body":"{\n  const { data } = await api.get<SyncStatus>('/sync/status')\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320063,"version":0},"$loki":24},{"name":"fetchSyncLogs","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\api\\sync.ts","lineNumber":14,"language":"typescript","dependencies":[],"purpose":"Function fetchSyncLogs implementation","context":"Located in sync.ts","metadata":{"kind":"function","isAsync":true,"isExported":true,"parameterCount":2,"functionCalls":["./request#api.get"],"usedImports":["PageResult","SyncLog","api"],"body":"{\n  const { data } = await api.get<PageResult<SyncLog>>('/sync/logs', {\n    params: { pageNum, pageSize },\n  })\n  return data\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320064,"version":0},"$loki":25}],"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\components\\Layout.tsx":[{"name":"AppLayout","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\components\\Layout.tsx","lineNumber":24,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Layout.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useNavigate","useLocation","antd#theme.useToken","join","slice","filter","location.pathname.split","navigate","getFullYear"],"usedImports":["useNavigate","useLocation","theme","Layout","Menu","Outlet"],"unusedImports":["useState","FolderOutlined"],"body":"{\n  const navigate = useNavigate()\n  const location = useLocation()\n  const { token } = theme.useToken()\n\n  const currentKey = '/' + location.pathname.split('/').filter(Boolean).slice(0, 1).join('/') || '/'\n  const selectedKey = currentKey === '/ai' ? '/ai/classify' : currentKey\n\n  return (\n    <Layout style={{ minHeight: '100vh' }}>\n      <Header\n        style={{\n          display: 'flex',\n          alignItems: 'center',\n          justifyContent: 'space-between',\n          background: token.colorBgContainer,\n          borderBottom: `1px solid ${token.colorBorderSecondary}`,\n          paddingInline: 24,\n          height: 56,\n          position: 'sticky',\n          top: 0,\n          zIndex: 100,\n        }}\n      >\n        <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>\n          <Text strong style={{ fontSize: 18, color: token.colorPrimary }}>\n            GitHub Stars\n          </Text>\n        </div>\n        <Menu\n          mode=\"horizontal\"\n          selectedKeys={[selectedKey]}\n          items={navItems}\n          onClick={({ key }) => navigate(key)}\n          style={{ flex: 1, justifyContent: 'flex-end', border: 'none', minWidth: 0 }}\n        />\n      </Header>\n      <Content style={{ padding: '16px 24px', maxWidth: 1400, width: '100%', margin: '0 auto' }}>\n        <Outlet />\n      </Content>\n      <Footer style={{ textAlign: 'center', color: token.colorTextTertiary, fontSize: 12 }}>\n        GitHub Stars 管理系统 ©{new Date().getFullYear()}\n      </Footer>\n    </Layout>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useNavigate","line":25,"customHook":true},{"name":"useLocation","line":26,"customHook":true}],"jsxElements":["Layout","Header","div","Text","Menu","Content","Outlet","Footer"],"complexity":2,"calledBy":[]},"meta":{"revision":0,"created":1780675320065,"version":0},"$loki":26}],"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\main.tsx":[],"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx":[{"name":"formatDateTime","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":11,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Function formatDateTime implementation","context":"Located in CategoryDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["format","dayjs"],"usedImports":["dayjs"],"body":"{\n  if (!value) return '-'\n  return dayjs(value).format('YYYY-MM-DD HH:mm:ss')\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320068,"version":0},"$loki":27},{"name":"CategoryDetail","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":16,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryDetail.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["useParams","antd#App.useApp","useNavigate","useState","useState","useState","useState","setLoading","../api/categories#categoriesApi.fetchAllCategories","setAllCategories","data.find","Number","setCategory","message.error","setLoading","useEffect","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#fetchData","modal.confirm","setReclassifying","../api/categories#categoriesApi.reclassifyCategory","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#fetchData","message.error","message.error","setReclassifying","navigate","navigate","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#formatDateTime","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#formatDateTime","navigate"],"usedImports":["useParams","App","useNavigate","useState","Category","categoriesApi","useEffect","Spin","Breadcrumb","Empty","Button","ArrowLeftOutlined","Card","FolderOutlined","Descriptions","ThunderboltOutlined"],"body":"{\n  const { id } = useParams<{ id: string }>()\n  const { message, modal } = App.useApp()\n  const navigate = useNavigate()\n\n  const [category, setCategory] = useState<Category | null>(null)\n  const [allCategories, setAllCategories] = useState<Category[]>([])\n  const [reclassifying, setReclassifying] = useState(false)\n  const [loading, setLoading] = useState(false)\n\n  const fetchData = async () => {\n    setLoading(true)\n    try {\n      const data = await categoriesApi.fetchAllCategories()\n      setAllCategories(data)\n      const current = data.find((c) => c.id === Number(id))\n      if (current) {\n        setCategory(current)\n      }\n    } catch {\n      message.error('获取分类信息失败')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    if (id) {\n      fetchData()\n    }\n  }, [id])\n\n  const handleReclassify = () => {\n    if (!category) return\n    modal.confirm({\n      title: 'AI 重分类',\n      content: `将对分类「${category.name}」下的仓库使用 AI 重新进行分类，可能需要一些时间。是否继续？`,\n      okText: '开始重分类',\n      cancelText: '取消',\n      onOk: async () => {\n        setReclassifying(true)\n        try {\n          const res = await categoriesApi.reclassifyCategory(category.id, 8)\n          if (res.success) {\n            message.success('AI 重分类任务已触发，请稍后刷新查看结果')\n            fetchData()\n          } else {\n            message.error(res.message || 'AI 重分类失败')\n          }\n        } catch {\n          message.error('AI 重分类请求失败，请稍后重试')\n        } finally {\n          setReclassifying(false)\n        }\n      },\n    })\n  }\n\n  if (loading && !category) {\n    return (\n      <div style={{ textAlign: 'center', paddingTop: 100 }}>\n        <Spin size=\"large\" />\n      </div>\n    )\n  }\n\n  if (!loading && !category) {\n    return (\n      <div>\n        <Breadcrumb\n          items={[\n            { title: <a onClick={() => navigate('/categories')}>分类管理</a> },\n            { title: '未找到' },\n          ]}\n          style={{ marginBottom: 24 }}\n        />\n        <Empty description=\"分类不存在或已被删除\" />\n        <div style={{ textAlign: 'center', marginTop: 16 }}>\n          <Button icon={<ArrowLeftOutlined />} onClick={() => navigate('/categories')}>\n            返回分类列表\n          </Button>\n        </div>\n      </div>\n    )\n  }\n\n  return (\n    <div>\n      <Breadcrumb\n        items={[\n          { title: <a onClick={() => navigate('/categories')}>分类管理</a> },\n          { title: category?.name },\n        ]}\n        style={{ marginBottom: 24 }}\n      />\n\n      <Spin spinning={loading}>\n        <Card style={{ marginBottom: 24 }}>\n          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>\n            <div>\n              <Title level={4} style={{ marginBottom: 4 }}>\n                <FolderOutlined style={{ marginRight: 8 }} />\n                {category?.name}\n              </Title>\n              {category?.description && (\n                <Paragraph type=\"secondary\" style={{ marginBottom: 12, maxWidth: 600 }}>\n                  {category.description}\n                </Paragraph>\n              )}\n              <Descriptions size=\"small\" column={3}>\n                <Descriptions.Item label=\"仓库数量\">{category?.repoCount ?? 0}</Descriptions.Item>\n                <Descriptions.Item label=\"排序\">{category?.sortOrder ?? 0}</Descriptions.Item>\n                <Descriptions.Item label=\"创建时间\">\n                  {formatDateTime(category?.createdAt ?? null)}\n                </Descriptions.Item>\n                <Descriptions.Item label=\"更新时间\">\n                  {formatDateTime(category?.updatedAt ?? null)}\n                </Descriptions.Item>\n              </Descriptions>\n            </div>\n            <Button\n              type=\"primary\"\n              icon={<ThunderboltOutlined />}\n              onClick={handleReclassify}\n              loading={reclassifying}\n            >\n              AI 重分类\n            </Button>\n          </div>\n        </Card>\n\n        <Card title=\"仓库列表\">\n          <Empty description=\"仓库列表功能需要后端提供分类下仓库查询的 JSON API，敬请期待\" />\n        </Card>\n\n        <div style={{ marginTop: 16, textAlign: 'center' }}>\n          <Button icon={<ArrowLeftOutlined />} onClick={() => navigate('/categories')}>\n            返回分类列表\n          </Button>\n        </div>\n      </Spin>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useParams","line":17,"customHook":true},{"name":"useNavigate","line":19,"customHook":true},{"name":"useState","line":21,"customHook":false},{"name":"useState","line":22,"customHook":false},{"name":"useState","line":23,"customHook":false},{"name":"useState","line":24,"customHook":false},{"name":"useEffect","line":42,"customHook":false}],"jsxElements":["div","Spin","Breadcrumb","a","Empty","Button","ArrowLeftOutlined","Card","Title","FolderOutlined","Paragraph","Descriptions","Descriptions.Item","ThunderboltOutlined"],"complexity":7,"calledBy":[]},"meta":{"revision":0,"created":1780675320069,"version":0},"$loki":28},{"name":"fetchData","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":26,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function fetchData","context":"Defined in CategoryDetail.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","../api/categories#categoriesApi.fetchAllCategories","setAllCategories","data.find","Number","setCategory","message.error","setLoading"],"usedImports":["categoriesApi"],"body":"{\n    setLoading(true)\n    try {\n      const data = await categoriesApi.fetchAllCategories()\n      setAllCategories(data)\n      const current = data.find((c) => c.id === Number(id))\n      if (current) {\n        setCategory(current)\n      }\n    } catch {\n      message.error('获取分类信息失败')\n    } finally {\n      setLoading(false)\n    }\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320074,"version":0},"$loki":29},{"name":"handleReclassify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx","lineNumber":48,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleReclassify","context":"Defined in CategoryDetail.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["modal.confirm","setReclassifying","../api/categories#categoriesApi.reclassifyCategory","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryDetail.tsx#fetchData","message.error","message.error","setReclassifying"],"usedImports":["categoriesApi"],"body":"{\n    if (!category) return\n    modal.confirm({\n      title: 'AI 重分类',\n      content: `将对分类「${category.name}」下的仓库使用 AI 重新进行分类，可能需要一些时间。是否继续？`,\n      okText: '开始重分类',\n      cancelText: '取消',\n      onOk: async () => {\n        setReclassifying(true)\n        try {\n          const res = await categoriesApi.reclassifyCategory(category.id, 8)\n          if (res.success) {\n            message.success('AI 重分类任务已触发，请稍后刷新查看结果')\n            fetchData()\n          } else {\n            message.error(res.message || 'AI 重分类失败')\n          }\n        } catch {\n          message.error('AI 重分类请求失败，请稍后重试')\n        } finally {\n          setReclassifying(false)\n        }\n      },\n    })\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320074,"version":0},"$loki":30}],"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx":[{"name":"formatDateTime","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":12,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Function formatDateTime implementation","context":"Located in CategoryList.tsx","metadata":{"kind":"function","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["format","dayjs"],"usedImports":["dayjs"],"body":"{\n  if (!value) return '-'\n  return dayjs(value).format('YYYY-MM-DD HH:mm:ss')\n}","calledBy":[]},"meta":{"revision":0,"created":1780675320076,"version":0},"$loki":31},{"name":"CategoryList","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":17,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["antd#App.useApp","useNavigate","useState","useState","useState","useState","useState","useState","useState","useState","setLoading","../api/categories#categoriesApi.fetchAllCategories","setCategories","message.error","setLoading","useEffect","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","setEditId","setFormName","setFormDesc","setModalOpen","setEditId","setFormName","setFormDesc","setModalOpen","setModalOpen","setEditId","setFormName","setFormDesc","formName.trim","message.warning","setSaving","../api/categories#categoriesApi.updateCategory","formName.trim","formDesc.trim","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#handleModalClose","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","../api/categories#categoriesApi.createCategory","formName.trim","formDesc.trim","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#handleModalClose","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error","setSaving","modal.confirm","../api/categories#categoriesApi.deleteCategory","message.success","setSelectedRowKeys","prev.filter","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error","message.warning","modal.confirm","../api/categories#categoriesApi.batchDeleteCategories","message.success","setSelectedRowKeys","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error","navigate","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#formatDateTime","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#openEditModal","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#handleDelete","setSelectedRowKeys","setFormName","setFormDesc"],"usedImports":["App","useNavigate","useState","Category","categoriesApi","useEffect","Button","EditOutlined","DeleteOutlined","PlusOutlined","ReloadOutlined","Table","Empty","Modal","Input"],"body":"{\n  const { message, modal } = App.useApp()\n  const navigate = useNavigate()\n\n  const [categories, setCategories] = useState<Category[]>([])\n  const [loading, setLoading] = useState(false)\n  const [selectedRowKeys, setSelectedRowKeys] = useState<React.Key[]>([])\n  const [modalOpen, setModalOpen] = useState(false)\n  const [editId, setEditId] = useState<number | null>(null)\n  const [formName, setFormName] = useState('')\n  const [formDesc, setFormDesc] = useState('')\n  const [saving, setSaving] = useState(false)\n\n  const fetchData = async () => {\n    setLoading(true)\n    try {\n      const data = await categoriesApi.fetchAllCategories()\n      setCategories(data)\n    } catch {\n      message.error('获取分类列表失败')\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    fetchData()\n  }, [])\n\n  const openCreateModal = () => {\n    setEditId(null)\n    setFormName('')\n    setFormDesc('')\n    setModalOpen(true)\n  }\n\n  const openEditModal = (record: Category) => {\n    setEditId(record.id)\n    setFormName(record.name)\n    setFormDesc(record.description || '')\n    setModalOpen(true)\n  }\n\n  const handleModalClose = () => {\n    setModalOpen(false)\n    setEditId(null)\n    setFormName('')\n    setFormDesc('')\n  }\n\n  const handleSave = async () => {\n    if (!formName.trim()) {\n      message.warning('请输入分类名称')\n      return\n    }\n    setSaving(true)\n    try {\n      if (editId !== null) {\n        const res = await categoriesApi.updateCategory(editId, formName.trim(), formDesc.trim() || undefined)\n        if (res.success) {\n          message.success('更新成功')\n          handleModalClose()\n          fetchData()\n        } else {\n          message.error(res.message || '更新失败')\n        }\n      } else {\n        const res = await categoriesApi.createCategory(formName.trim(), formDesc.trim() || undefined)\n        if (res.success) {\n          message.success('创建成功')\n          handleModalClose()\n          fetchData()\n        } else {\n          message.error(res.message || '创建失败')\n        }\n      }\n    } catch {\n      message.error('操作失败，请稍后重试')\n    } finally {\n      setSaving(false)\n    }\n  }\n\n  const handleDelete = (id: number, name: string) => {\n    modal.confirm({\n      title: '确认删除',\n      content: `确定要删除分类「${name}」吗？该分类下的仓库将变为未分类状态。`,\n      okText: '确认删除',\n      okType: 'danger',\n      cancelText: '取消',\n      onOk: async () => {\n        try {\n          const res = await categoriesApi.deleteCategory(id)\n          if (res.success) {\n            message.success('删除成功')\n            setSelectedRowKeys((prev) => prev.filter((k) => k !== id))\n            fetchData()\n          } else {\n            message.error(res.message || '删除失败')\n          }\n        } catch {\n          message.error('删除失败，请稍后重试')\n        }\n      },\n    })\n  }\n\n  const handleBatchDelete = () => {\n    if (selectedRowKeys.length === 0) {\n      message.warning('请先选择要删除的分类')\n      return\n    }\n    modal.confirm({\n      title: '批量删除',\n      content: `确定要删除选中的 ${selectedRowKeys.length} 个分类吗？分类下的仓库将变为未分类状态。`,\n      okText: '确认删除',\n      okType: 'danger',\n      cancelText: '取消',\n      onOk: async () => {\n        try {\n          const res = await categoriesApi.batchDeleteCategories(selectedRowKeys as number[])\n          if (res.success) {\n            message.success('批量删除成功')\n            setSelectedRowKeys([])\n            fetchData()\n          } else {\n            message.error(res.message || '批量删除失败')\n          }\n        } catch {\n          message.error('批量删除失败，请稍后重试')\n        }\n      },\n    })\n  }\n\n  const columns = [\n    { title: 'ID', dataIndex: 'id', key: 'id', width: 70 },\n    {\n      title: '分类名称',\n      dataIndex: 'name',\n      key: 'name',\n      render: (name: string, record: Category) => (\n        <a onClick={() => navigate(`/categories/${record.id}`)}>{name}</a>\n      ),\n    },\n    {\n      title: '描述',\n      dataIndex: 'description',\n      key: 'description',\n      ellipsis: true,\n      render: (v: string | null) => v || '-',\n    },\n    {\n      title: '仓库数量',\n      dataIndex: 'repoCount',\n      key: 'repoCount',\n      width: 100,\n      align: 'right' as const,\n    },\n    {\n      title: '创建时间',\n      dataIndex: 'createdAt',\n      key: 'createdAt',\n      width: 180,\n      render: (v: string) => formatDateTime(v),\n    },\n    {\n      title: '操作',\n      key: 'action',\n      width: 150,\n      render: (_: unknown, record: Category) => (\n        <div style={{ display: 'flex', gap: 8 }}>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            icon={<EditOutlined />}\n            onClick={() => openEditModal(record)}\n          >\n            编辑\n          </Button>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            danger\n            icon={<DeleteOutlined />}\n            onClick={() => handleDelete(record.id, record.name)}\n          >\n            删除\n          </Button>\n        </div>\n      ),\n    },\n  ]\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        分类管理\n      </Title>\n\n      <div style={{ marginBottom: 16, display: 'flex', gap: 8 }}>\n        <Button type=\"primary\" icon={<PlusOutlined />} onClick={openCreateModal}>\n          新增分类\n        </Button>\n        {selectedRowKeys.length > 0 && (\n          <Button danger icon={<DeleteOutlined />} onClick={handleBatchDelete}>\n            批量删除 ({selectedRowKeys.length})\n          </Button>\n        )}\n        <Button icon={<ReloadOutlined />} onClick={fetchData} loading={loading}>\n          刷新\n        </Button>\n      </div>\n\n      <Table\n        rowKey=\"id\"\n        columns={columns}\n        dataSource={categories}\n        loading={loading}\n        rowSelection={{\n          selectedRowKeys,\n          onChange: (keys) => setSelectedRowKeys(keys),\n        }}\n        pagination={{\n          showTotal: (total) => `共 ${total} 条`,\n          showSizeChanger: true,\n          pageSizeOptions: ['10', '20', '50'],\n        }}\n        locale={{\n          emptyText: <Empty description=\"暂无分类数据\" />,\n        }}\n        scroll={{ x: 750 }}\n      />\n\n      <Modal\n        title={editId !== null ? '编辑分类' : '新增分类'}\n        open={modalOpen}\n        onOk={handleSave}\n        onCancel={handleModalClose}\n        confirmLoading={saving}\n        destroyOnClose\n      >\n        <div style={{ display: 'flex', flexDirection: 'column', gap: 16, paddingTop: 8 }}>\n          <div>\n            <div style={{ marginBottom: 4, fontWeight: 500 }}>名称</div>\n            <Input\n              placeholder=\"请输入分类名称\"\n              value={formName}\n              onChange={(e) => setFormName(e.target.value)}\n              maxLength={50}\n            />\n          </div>\n          <div>\n            <div style={{ marginBottom: 4, fontWeight: 500 }}>描述</div>\n            <TextArea\n              placeholder=\"请输入分类描述（可选）\"\n              value={formDesc}\n              onChange={(e) => setFormDesc(e.target.value)}\n              rows={3}\n              maxLength={200}\n            />\n          </div>\n        </div>\n      </Modal>\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useNavigate","line":19,"customHook":true},{"name":"useState","line":21,"customHook":false},{"name":"useState","line":22,"customHook":false},{"name":"useState","line":23,"customHook":false},{"name":"useState","line":24,"customHook":false},{"name":"useState","line":25,"customHook":false},{"name":"useState","line":26,"customHook":false},{"name":"useState","line":27,"customHook":false},{"name":"useState","line":28,"customHook":false},{"name":"useEffect","line":42,"customHook":false}],"jsxElements":["a","div","Button","EditOutlined","DeleteOutlined","Title","PlusOutlined","ReloadOutlined","Table","Empty","Modal","Input","TextArea"],"complexity":9,"calledBy":[]},"meta":{"revision":0,"created":1780675320076,"version":0},"$loki":32},{"name":"fetchData","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":30,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function fetchData","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["setLoading","../api/categories#categoriesApi.fetchAllCategories","setCategories","message.error","setLoading"],"usedImports":["categoriesApi"],"body":"{\n    setLoading(true)\n    try {\n      const data = await categoriesApi.fetchAllCategories()\n      setCategories(data)\n    } catch {\n      message.error('获取分类列表失败')\n    } finally {\n      setLoading(false)\n    }\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320082,"version":0},"$loki":33},{"name":"openCreateModal","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":46,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function openCreateModal","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["setEditId","setFormName","setFormDesc","setModalOpen"],"usedImports":[],"body":"{\n    setEditId(null)\n    setFormName('')\n    setFormDesc('')\n    setModalOpen(true)\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320082,"version":0},"$loki":34},{"name":"openEditModal","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":53,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function openEditModal","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":1,"functionCalls":["setEditId","setFormName","setFormDesc","setModalOpen"],"usedImports":["Category"],"body":"{\n    setEditId(record.id)\n    setFormName(record.name)\n    setFormDesc(record.description || '')\n    setModalOpen(true)\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320083,"version":0},"$loki":35},{"name":"handleModalClose","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":60,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleModalClose","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["setModalOpen","setEditId","setFormName","setFormDesc"],"usedImports":[],"body":"{\n    setModalOpen(false)\n    setEditId(null)\n    setFormName('')\n    setFormDesc('')\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320084,"version":0},"$loki":36},{"name":"handleSave","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":67,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleSave","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":true,"isExported":false,"parameterCount":0,"functionCalls":["formName.trim","message.warning","setSaving","../api/categories#categoriesApi.updateCategory","formName.trim","formDesc.trim","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#handleModalClose","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","../api/categories#categoriesApi.createCategory","formName.trim","formDesc.trim","message.success","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#handleModalClose","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error","setSaving"],"usedImports":["categoriesApi"],"body":"{\n    if (!formName.trim()) {\n      message.warning('请输入分类名称')\n      return\n    }\n    setSaving(true)\n    try {\n      if (editId !== null) {\n        const res = await categoriesApi.updateCategory(editId, formName.trim(), formDesc.trim() || undefined)\n        if (res.success) {\n          message.success('更新成功')\n          handleModalClose()\n          fetchData()\n        } else {\n          message.error(res.message || '更新失败')\n        }\n      } else {\n        const res = await categoriesApi.createCategory(formName.trim(), formDesc.trim() || undefined)\n        if (res.success) {\n          message.success('创建成功')\n          handleModalClose()\n          fetchData()\n        } else {\n          message.error(res.message || '创建失败')\n        }\n      }\n    } catch {\n      message.error('操作失败，请稍后重试')\n    } finally {\n      setSaving(false)\n    }\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320084,"version":0},"$loki":37},{"name":"handleDelete","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":100,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleDelete","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":2,"functionCalls":["modal.confirm","../api/categories#categoriesApi.deleteCategory","message.success","setSelectedRowKeys","prev.filter","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error"],"usedImports":["categoriesApi"],"body":"{\n    modal.confirm({\n      title: '确认删除',\n      content: `确定要删除分类「${name}」吗？该分类下的仓库将变为未分类状态。`,\n      okText: '确认删除',\n      okType: 'danger',\n      cancelText: '取消',\n      onOk: async () => {\n        try {\n          const res = await categoriesApi.deleteCategory(id)\n          if (res.success) {\n            message.success('删除成功')\n            setSelectedRowKeys((prev) => prev.filter((k) => k !== id))\n            fetchData()\n          } else {\n            message.error(res.message || '删除失败')\n          }\n        } catch {\n          message.error('删除失败，请稍后重试')\n        }\n      },\n    })\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320085,"version":0},"$loki":38},{"name":"handleBatchDelete","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":124,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"Arrow function handleBatchDelete","context":"Defined in CategoryList.tsx","metadata":{"kind":"arrow","isAsync":false,"isExported":false,"parameterCount":0,"functionCalls":["message.warning","modal.confirm","../api/categories#categoriesApi.batchDeleteCategories","message.success","setSelectedRowKeys","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx#fetchData","message.error","message.error"],"usedImports":["categoriesApi"],"body":"{\n    if (selectedRowKeys.length === 0) {\n      message.warning('请先选择要删除的分类')\n      return\n    }\n    modal.confirm({\n      title: '批量删除',\n      content: `确定要删除选中的 ${selectedRowKeys.length} 个分类吗？分类下的仓库将变为未分类状态。`,\n      okText: '确认删除',\n      okType: 'danger',\n      cancelText: '取消',\n      onOk: async () => {\n        try {\n          const res = await categoriesApi.batchDeleteCategories(selectedRowKeys as number[])\n          if (res.success) {\n            message.success('批量删除成功')\n            setSelectedRowKeys([])\n            fetchData()\n          } else {\n            message.error(res.message || '批量删除失败')\n          }\n        } catch {\n          message.error('批量删除失败，请稍后重试')\n        }\n      },\n    })\n  }","calledBy":[]},"meta":{"revision":0,"created":1780675320087,"version":0},"$loki":39},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":158,"startLine":158,"endLine":160,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["a"],"isExported":false,"complexity":1,"body":"(\n        <a onClick={() => navigate(`/categories/${record.id}`)}>{name}</a>\n      )","usedImports":["Category"],"calledBy":[]},"meta":{"revision":0,"created":1780675320088,"version":0},"$loki":40},{"name":"AnonymousComponent","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\CategoryList.tsx","lineNumber":187,"startLine":187,"endLine":207,"language":"typescript","dependencies":["react","react-router-dom","antd","@ant-design/icons","dayjs"],"purpose":"React functional component","context":"Located in CategoryList.tsx","metadata":{"entityType":"component","componentType":"functional","props":[],"hooks":[],"jsxElements":["div","Button","EditOutlined","DeleteOutlined"],"isExported":false,"complexity":1,"body":"(\n        <div style={{ display: 'flex', gap: 8 }}>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            icon={<EditOutlined />}\n            onClick={() => openEditModal(record)}\n          >\n            编辑\n          </Button>\n          <Button\n            type=\"link\"\n            size=\"small\"\n            danger\n            icon={<DeleteOutlined />}\n            onClick={() => handleDelete(record.id, record.name)}\n          >\n            删除\n          </Button>\n        </div>\n      )","usedImports":["Category","Button","EditOutlined","DeleteOutlined"],"calledBy":[]},"meta":{"revision":0,"created":1780675320091,"version":0},"$loki":41}],"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx":[{"name":"Classify","filePath":"D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx","lineNumber":16,"language":"typescript","dependencies":["react","antd","@ant-design/icons"],"purpose":"React functional component","context":"Located in Classify.tsx","metadata":{"kind":"function","isAsync":false,"isExported":true,"parameterCount":0,"functionCalls":["antd#App.useApp","useState","useState","useState","useState","useState","useState","useState","useState","useRef","setLoading","../api/classify#classifyApi.fetchClassifyRepos","Array.isArray","setRepos","Array.isArray","setRepos","setRepos","message.error","setRepos","setLoading","useEffect","D:\\WorkeSpaceCoding\\java\\githubstars\\frontend\\src\\pages\\Classify.tsx#fetchRepos","useMemo","repos.forEach","set.add","sort","Array.from","useMemo","keyword.toLowerCase","list.filter","includes","r.fullName.toLowerCase","includes","r.description.toLowerCase","list.filter","setSelectedIds","filteredRepos.map","setSelectedIds","setClassifying","setResults","../api/classify#classifyApi.executeClassify","setResults","message.success","Object.keys","setTimeout","resultsRef.current.scrollIntoView","message.error","message.error","setClassifying","v.slice","toFixed","String","languages.map","setKeyword","setSelectedIds","Object.keys","map","Object.entries","repoList.map","r.description.slice"],"usedImports":["App","useState","GithubRepo","useRef","classifyApi","useEffect","useMemo","GithubOutlined","Tag","Card","Row","Col","Select","Input","Button","ClearOutlined","RobotOutlined","Table","Spin"],"body":"{\n  const { message } = App.useApp()\n\n  const [repos, setRepos] = useState<GithubRepo[]>([])\n  const [selectedIds, setSelectedIds] = useState<number[]>([])\n  const [keyword, setKeyword] = useState('')\n  const [language, setLanguage] = useState('')\n  const [topN, setTopN] = useState(8)\n  const [loading, setLoading] = useState(false)\n  const [classifying, setClassifying] = useState(false)\n  const [results, setResults] = useState<Record<string, GithubRepo[]>>({})\n\n  const resultsRef = useRef<HTMLDivElement>(null)\n\n  const fetchRepos = async () => {\n    setLoading(true)\n    try {\n      const res = await classifyApi.fetchClassifyRepos()\n      if (Array.isArray(res)) {\n        setRepos(res)\n      } else if (res && typeof res === 'object' && 'repos' in res && Array.isArray((res as Record<string, unknown>).repos)) {\n        setRepos((res as Record<string, GithubRepo[]>).repos)\n      } else {\n        setRepos([])\n      }\n    } catch {\n      message.error('获取仓库列表失败')\n      setRepos([])\n    } finally {\n      setLoading(false)\n    }\n  }\n\n  useEffect(() => {\n    fetchRepos()\n  }, [])\n\n  const languages = useMemo(() => {\n    const set = new Set<string>()\n    repos.forEach((r) => {\n      if (r.language) set.add(r.language)\n    })\n    return Array.from(set).sort()\n  }, [repos])\n\n  const filteredRepos = useMemo(() => {\n    let list = repos\n    if (keyword) {\n      const kw = keyword.toLowerCase()\n      list = list.filter(\n        (r) =>\n          r.fullName.toLowerCase().includes(kw) ||\n          (r.description !== null && r.description.toLowerCase().includes(kw))\n      )\n    }\n    if (language) {\n      list = list.filter((r) => r.language === language)\n    }\n    return list\n  }, [repos, keyword, language])\n\n  const handleSelectAll = () => {\n    setSelectedIds(filteredRepos.map((r) => r.id))\n  }\n\n  const handleClearSelection = () => {\n    setSelectedIds([])\n  }\n\n  const handleClassify = async () => {\n    if (selectedIds.length === 0) return\n    setClassifying(true)\n    setResults({})\n    try {\n      const res = await classifyApi.executeClassify(selectedIds, topN)\n      if (res.success && res.categories) {\n        setResults(res.categories)\n        message.success(`AI 分类完成，共 ${Object.keys(res.categories).length} 个分类`)\n        setTimeout(() => {\n          resultsRef.current?.scrollIntoView({ behavior: 'smooth', block: 'start' })\n        }, 150)\n      } else {\n        message.error('AI 分类失败，请稍后重试')\n      }\n    } catch {\n      message.error('AI 分类请求失败')\n    } finally {\n      setClassifying(false)\n    }\n  }\n\n  const columns = [\n    {\n      title: '仓库名',\n      dataIndex: 'fullName',\n      key: 'fullName',\n      width: 240,\n      render: (_: string, record: GithubRepo) => (\n        <a href={record.htmlUrl} target=\"_blank\" rel=\"noopener noreferrer\">\n          <GithubOutlined style={{ marginRight: 6 }} />\n          {record.fullName}\n        </a>\n      ),\n    },\n    {\n      title: '描述',\n      dataIndex: 'description',\n      key: 'description',\n      ellipsis: true,\n      render: (v: string | null) => {\n        if (!v) return '-'\n        return v.length > 80 ? v.slice(0, 80) + '...' : v\n      },\n    },\n    {\n      title: '语言',\n      dataIndex: 'language',\n      key: 'language',\n      width: 120,\n      render: (lang: string | null) =>\n        lang ? <Tag color=\"blue\">{lang}</Tag> : <Tag color=\"default\">-</Tag>,\n    },\n    {\n      title: 'Star数',\n      dataIndex: 'starsCount',\n      key: 'starsCount',\n      width: 100,\n      align: 'right' as const,\n      render: (v: number) => {\n        if (v >= 1000) return (v / 1000).toFixed(1) + 'K'\n        return String(v)\n      },\n    },\n  ]\n\n  return (\n    <div>\n      <Title level={3} style={{ marginBottom: 24 }}>\n        AI 智能分类\n      </Title>\n\n      <Card style={{ marginBottom: 16 }}>\n        <Row gutter={[12, 12]} align=\"middle\">\n          <Col>\n            <Select\n              placeholder=\"选择语言\"\n              allowClear\n              style={{ width: 150 }}\n              value={language || undefined}\n              onChange={setLanguage}\n              options={languages.map((l) => ({ label: l, value: l }))}\n            />\n          </Col>\n          <Col>\n            <Input.Search\n              placeholder=\"搜索仓库...\"\n              allowClear\n              style={{ width: 250 }}\n              value={keyword}\n              onChange={(e) => setKeyword(e.target.value)}\n              onSearch={setKeyword}\n            />\n          </Col>\n          <Col>\n            <Button onClick={handleSelectAll}>全选</Button>\n          </Col>\n          <Col>\n            <Button onClick={handleClearSelection} icon={<ClearOutlined />}>\n              清除选择\n            </Button>\n          </Col>\n          <Col>\n            <Text type=\"secondary\">\n              已选 <Text strong>{selectedIds.length}</Text> 项\n            </Text>\n          </Col>\n          <Col>\n            <Select\n              value={topN}\n              onChange={setTopN}\n              options={TOP_N_OPTIONS}\n              style={{ width: 100 }}\n            />\n          </Col>\n          <Col>\n            <Button\n              type=\"primary\"\n              icon={<RobotOutlined />}\n              disabled={selectedIds.length === 0}\n              onClick={handleClassify}\n            >\n              开始 AI 分类\n            </Button>\n          </Col>\n        </Row>\n      </Card>\n\n      <Card>\n        <Table\n          rowSelection={{\n            selectedRowKeys: selectedIds,\n            onChange: (keys) => setSelectedIds(keys as number[]),\n          }}\n          columns={columns}\n          dataSource={filteredRepos}\n          rowKey=\"id\"\n          loading={loading}\n          pagination={{\n            showSizeChanger: true,\n            showTotal: (total: number) => `共 ${total} 个仓库`,\n            pageSizeOptions: ['10', '20', '50', '100'],\n          }}\n          scroll={{ x: 700 }}\n          size=\"small\"\n        />\n      </Card>\n\n      {Object.keys(results).length > 0 && (\n        <div ref={resultsRef} style={{ marginTop: 24 }}>\n          <Title level={4} style={{ marginBottom: 16 }}>\n            分类结果\n          </Title>\n          <Row gutter={[16, 16]}>\n            {Object.entries(results).map(([category, repoList]) => (\n              <Col xs={24} md={12} lg={8} key={category}>\n                <Card\n                  title={\n                    <Text strong style={{ fontSize: 15 }}>\n                      {category}\n                    </Text>\n                  }\n                  extra={<Tag>{repoList.length} 个仓库</Tag>}\n                  style={{ height: '100%' }}\n                >\n                  {repoList.map((r) => (\n                    <div key={r.id} style={{ padding: '4px 0' }}>\n                      <a\n                        href={r.htmlUrl}\n                        target=\"_blank\"\n                        rel=\"noopener noreferrer\"\n                        style={{ fontSize: 13 }}\n                      >\n                        {r.fullName}\n                      </a>\n                      {r.description && (\n                        <div style={{ color: '#888', fontSize: 12, marginTop: 2 }}>\n                          {r.description.length > 60\n                            ? r.description.slice(0, 60) + '...'\n                            : r.description}\n                        </div>\n                      )}\n                    </div>\n                  ))}\n                </Card>\n              </Col>\n            ))}\n          </Row>\n        </div>\n      )}\n\n      {classifying && (\n        <div\n          style={{\n            position: 'fixed',\n            inset: 0,\n            background: 'rgba(0, 0, 0, 0.45)',\n            display: 'flex',\n            flexDirection: 'column',\n            alignItems: 'center',\n            justifyContent: 'center',\n            zIndex: 9999,\n          }}\n        >\n          <Spin size=\"large\" />\n          <div style={{ color: '#fff', fontSize: 16, marginTop: 16 }}>\n            AI 正在分析仓库...\n          </div>\n        </div>\n      )}\n    </div>\n  )\n}","entityType":"component","componentType":"functional","props":[],"hooks":[{"name":"useState","line":19,"customHook":false},{"name":"useState","line":20,"customHook":false},{"name":"useState","line":21,"customHook":false},{"name":"useState","line":22,"customHook":false},{"name":"useState","line":23,"customHook":false},{"name":"useState","line":24,"customHook":false},{"name":"useState","line":25,"customHook":false},{"name":"useState","line":26,"customHook":false},{"name":"useRef","line":28,"customHook":false},{"name":"useEffect","line":49,"customHook":false},{"name":"useMemo","line":53,"customHook":false},{"name":"useMemo","line":61,"customHook":false}],"jsxElements":["a","GithubOutlin